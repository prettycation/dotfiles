{{- $taskName := .TaskName -}}
{{- $mode := "terminal" -}}
{{- if hasKey . "Mode" -}}
{{- $mode = .Mode -}}
{{- end -}}
{{- $logName := $taskName -}}
{{- if hasKey . "LogName" -}}
{{- $logName = .LogName -}}
{{- end -}}
param(
    [switch]$ElevatedChild,
    [string]$TargetUser,
    [string]$TargetProfilePath,
    [string]$LogPath
)

$script:ChezmoiUacTaskName = "{{ $taskName }}"
$script:ChezmoiUacMode = "{{ $mode }}"
$script:ChezmoiUacLogName = "{{ $logName }}"

$ErrorActionPreference = "Stop"

# ==================================================================================
# --- [UAC / XDG Bootstrap] ---
# ==================================================================================

# 此脚本需要管理员权限。

# Mode:
# - terminal: parent 当前终端 -> UAC wrapper -> child stdout/stderr 临时文件
#             -> parent 读取并打印到当前终端 -> 清理临时文件
# - log     : parent 当前终端 -> UAC wrapper -> child stdout/stderr 临时文件
#             -> wrapper 合并到 XDG state 日志 -> 清理临时文件

# 临时 wrapper / child 文件路径：
#   $XDG_RUNTIME_DIR\chezmoi\<task>\

# 如果未设置 XDG_RUNTIME_DIR，则回退到：
#   $XDG_CACHE_HOME\chezmoi\tmp\<task>\

# 如果未设置 XDG_CACHE_HOME，则最终回退到：
#   $HOME\.cache\chezmoi\tmp\<task>\

# log mode 日志路径：
#   $XDG_STATE_HOME\chezmoi\logs\<log-name>.log

# 如果未设置 XDG_STATE_HOME，则回退到：
#   $HOME\.local\state\chezmoi\logs\<log-name>.log

# ==================================================================================

function Test-IsAdministrator {
    $identity = [System.Security.Principal.WindowsIdentity]::GetCurrent()
    $principal = [System.Security.Principal.WindowsPrincipal]::new($identity)

    return $principal.IsInRole([System.Security.Principal.WindowsBuiltInRole]::Administrator)
}

function Test-IsAbsolutePath {
    param(
        [string]$Path
    )

    if ([string]::IsNullOrWhiteSpace($Path)) {
        return $false
    }

    return [System.IO.Path]::IsPathRooted($Path)
}

function Get-TargetProfilePath {
    if (-not [string]::IsNullOrWhiteSpace($TargetProfilePath)) {
        return $TargetProfilePath
    }

    if (-not [string]::IsNullOrWhiteSpace($env:USERPROFILE)) {
        return $env:USERPROFILE
    }

    return $HOME
}

function Get-XdgStateHome {
    param(
        [Parameter(Mandatory)]
        [string]$ProfilePath
    )

    if (Test-IsAbsolutePath -Path $env:XDG_STATE_HOME) {
        return $env:XDG_STATE_HOME
    }

    return [System.IO.Path]::Combine($ProfilePath, ".local", "state")
}

function Get-XdgCacheHome {
    param(
        [Parameter(Mandatory)]
        [string]$ProfilePath
    )

    if (Test-IsAbsolutePath -Path $env:XDG_CACHE_HOME) {
        return $env:XDG_CACHE_HOME
    }

    return [System.IO.Path]::Combine($ProfilePath, ".cache")
}

function Get-ChezmoiTempRoot {
    $profilePath = Get-TargetProfilePath

    if (Test-IsAbsolutePath -Path $env:XDG_RUNTIME_DIR) {
        $root = [System.IO.Path]::Combine($env:XDG_RUNTIME_DIR, "chezmoi", $script:ChezmoiUacTaskName)
    } else {
        $cacheHome = Get-XdgCacheHome -ProfilePath $profilePath
        $root = [System.IO.Path]::Combine($cacheHome, "chezmoi", "tmp", $script:ChezmoiUacTaskName)
    }

    if (-not (Test-Path -LiteralPath $root -PathType Container)) {
        $null = New-Item -Path $root -ItemType Directory -Force
    }

    return $root
}

function Get-ChezmoiLogPath {
    param(
        [switch]$Clear
    )

    if (-not [string]::IsNullOrWhiteSpace($LogPath)) {
        $path = $LogPath
    } else {
        $profilePath = Get-TargetProfilePath
        $stateHome = Get-XdgStateHome -ProfilePath $profilePath
        $root = [System.IO.Path]::Combine($stateHome, "chezmoi", "logs")
        $path = [System.IO.Path]::Combine($root, "$script:ChezmoiUacLogName.log")
    }

    $parent = Split-Path -Parent $path

    if (-not (Test-Path -LiteralPath $parent -PathType Container)) {
        $null = New-Item -Path $parent -ItemType Directory -Force
    }

    if ($Clear) {
        Set-Content -LiteralPath $path -Value "" -Encoding UTF8
    } elseif (-not (Test-Path -LiteralPath $path -PathType Leaf)) {
        $null = New-Item -Path $path -ItemType File -Force
    }

    return $path
}

function ConvertTo-PSLiteral {
    param(
        [Parameter(Mandatory)]
        [AllowEmptyString()]
        [string]$Value
    )

    return "'" + $Value.Replace("'", "''") + "'"
}

function Write-LogLine {
    param(
        [Parameter(Mandatory)]
        [string]$Path,

        [Parameter(Mandatory)]
        [string]$Message
    )

    Add-Content -LiteralPath $Path -Value ("[{0}] {1}" -f (Get-Date -Format o), $Message) -Encoding UTF8
}

function Remove-GeneratedFile {
    param(
        [string[]]$Path
    )

    foreach ($item in $Path) {
        if ([string]::IsNullOrWhiteSpace($item)) {
            continue
        }

        Remove-Item -LiteralPath $item -Force -ErrorAction SilentlyContinue
    }
}

function Remove-OldGeneratedFiles {
    param(
        [Parameter(Mandatory)]
        [string]$Root,

        [int]$OlderThanDays = 7
    )

    if (-not (Test-Path -LiteralPath $Root -PathType Container)) {
        return
    }

    $cutoff = (Get-Date).AddDays(-$OlderThanDays)
    $files = Get-ChildItem -LiteralPath $Root -Filter "chezmoi-$script:ChezmoiUacTaskName-*" -File -ErrorAction SilentlyContinue

    foreach ($file in $files) {
        if ($file.LastWriteTime -lt $cutoff) {
            Remove-Item -LiteralPath $file.FullName -Force -ErrorAction SilentlyContinue
        }
    }
}

function Read-TextFile {
    param(
        [Parameter(Mandatory)]
        [string]$Path
    )

    if (-not (Test-Path -LiteralPath $Path -PathType Leaf)) {
        return ""
    }

    $reader = [System.IO.StreamReader]::new($Path, $true)

    try {
        return $reader.ReadToEnd()
    } finally {
        $reader.Dispose()
    }
}

function Write-CapturedOutputToTerminal {
    param(
        [Parameter(Mandatory)]
        [string]$StdoutPath,

        [Parameter(Mandatory)]
        [string]$StderrPath
    )

    $stdoutText = Read-TextFile -Path $StdoutPath
    $stderrText = Read-TextFile -Path $StderrPath

    if (-not [string]::IsNullOrEmpty($stdoutText)) {
        [Console]::Out.Write($stdoutText)
    }

    if (-not [string]::IsNullOrEmpty($stderrText)) {
        [Console]::Error.Write($stderrText)
    }
}

function Append-FileToLog {
    param(
        [Parameter(Mandatory)]
        [string]$SourcePath,

        [Parameter(Mandatory)]
        [string]$DestinationPath,

        [Parameter(Mandatory)]
        [string]$Title
    )

    Write-LogLine -Path $DestinationPath -Message "----- $Title begin -----"

    if (Test-Path -LiteralPath $SourcePath -PathType Leaf) {
        $content = Get-Content -LiteralPath $SourcePath -Raw -ErrorAction SilentlyContinue

        if ($null -ne $content -and $content.Length -gt 0) {
            Add-Content -LiteralPath $DestinationPath -Value $content -Encoding UTF8
        }
    } else {
        Write-LogLine -Path $DestinationPath -Message "$Title file not found: $SourcePath"
    }

    Write-LogLine -Path $DestinationPath -Message "----- $Title end -----"
}

function Invoke-SelfElevatedIfNeeded {
    if (Test-IsAdministrator) {
        if ($script:ChezmoiUacMode -eq "log") {
            if ($ElevatedChild) {
                $currentLogPath = Get-ChezmoiLogPath
                Write-LogLine -Path $currentLogPath -Message "=== $script:ChezmoiUacTaskName elevated child entered ==="
                Write-LogLine -Path $currentLogPath -Message "elevated child identity: $([System.Security.Principal.WindowsIdentity]::GetCurrent().Name)"
                Write-LogLine -Path $currentLogPath -Message "target user: $TargetUser"
                Write-LogLine -Path $currentLogPath -Message "target profile: $(Get-TargetProfilePath)"
            } else {
                $currentLogPath = Get-ChezmoiLogPath -Clear
                Write-LogLine -Path $currentLogPath -Message "=== $script:ChezmoiUacTaskName direct admin run started ==="
                Write-LogLine -Path $currentLogPath -Message "identity: $([System.Security.Principal.WindowsIdentity]::GetCurrent().Name)"
                Write-LogLine -Path $currentLogPath -Message "target profile: $(Get-TargetProfilePath)"
            }
        }

        return
    }

    $targetUser = [System.Security.Principal.WindowsIdentity]::GetCurrent().Name
    $targetProfile = Get-TargetProfilePath
    $tempRoot = Get-ChezmoiTempRoot

    Remove-OldGeneratedFiles -Root $tempRoot -OlderThanDays 7

    if ($script:ChezmoiUacMode -eq "log") {
        $mainLogPath = Get-ChezmoiLogPath -Clear
        Write-LogLine -Path $mainLogPath -Message "=== $script:ChezmoiUacTaskName parent started ==="
        Write-LogLine -Path $mainLogPath -Message "parent identity: $targetUser"
        Write-LogLine -Path $mainLogPath -Message "target profile: $targetProfile"
        Write-LogLine -Path $mainLogPath -Message "script path: $PSCommandPath"
        Write-LogLine -Path $mainLogPath -Message "temp root: $tempRoot"
        Write-Warning "当前不是管理员权限，正在请求 UAC 提权以执行 $script:ChezmoiUacTaskName..."
        Write-Warning "日志路径: $mainLogPath"
    } else {
        $mainLogPath = ""
        Write-Warning "当前不是管理员权限，正在请求 UAC 提权以执行 $script:ChezmoiUacTaskName..."
    }

    if ([string]::IsNullOrWhiteSpace($PSCommandPath) -or -not (Test-Path -LiteralPath $PSCommandPath -PathType Leaf)) {
        if ($script:ChezmoiUacMode -eq "log") {
            Write-LogLine -Path $mainLogPath -Message "ERROR: PSCommandPath is empty or missing."
        } else {
            Write-Error "无法定位当前脚本路径，无法执行 UAC 提权。"
        }

        exit 1
    }

    $id = [guid]::NewGuid().ToString("N")
    $wrapperPath = [System.IO.Path]::Combine($tempRoot, "chezmoi-$script:ChezmoiUacTaskName-elevated-$id.ps1")
    $childScriptPath = [System.IO.Path]::Combine($tempRoot, "chezmoi-$script:ChezmoiUacTaskName-child-$id.ps1")
    $childStdoutPath = [System.IO.Path]::Combine($tempRoot, "chezmoi-$script:ChezmoiUacTaskName-child-$id.stdout.log")
    $childStderrPath = [System.IO.Path]::Combine($tempRoot, "chezmoi-$script:ChezmoiUacTaskName-child-$id.stderr.log")

    $scriptText = [System.IO.File]::ReadAllText($PSCommandPath, [System.Text.Encoding]::UTF8)
    $utf8Bom = [System.Text.UTF8Encoding]::new($true)
    [System.IO.File]::WriteAllText($childScriptPath, $scriptText, $utf8Bom)

    $taskNameLiteral = ConvertTo-PSLiteral -Value $script:ChezmoiUacTaskName
    $modeLiteral = ConvertTo-PSLiteral -Value $script:ChezmoiUacMode
    $scriptPathLiteral = ConvertTo-PSLiteral -Value $childScriptPath
    $targetUserLiteral = ConvertTo-PSLiteral -Value $targetUser
    $targetProfileLiteral = ConvertTo-PSLiteral -Value $targetProfile
    $mainLogPathLiteral = ConvertTo-PSLiteral -Value $mainLogPath
    $childStdoutLiteral = ConvertTo-PSLiteral -Value $childStdoutPath
    $childStderrLiteral = ConvertTo-PSLiteral -Value $childStderrPath

    $wrapper = @(
        '$ErrorActionPreference = "Stop"'
        '$taskName = ' + $taskNameLiteral
        '$mode = ' + $modeLiteral
        '$scriptPath = ' + $scriptPathLiteral
        '$targetUser = ' + $targetUserLiteral
        '$targetProfile = ' + $targetProfileLiteral
        '$mainLogPath = ' + $mainLogPathLiteral
        '$childStdoutPath = ' + $childStdoutLiteral
        '$childStderrPath = ' + $childStderrLiteral
        '$script:ExitCode = 1'
        ''
        'function Write-LogLine {'
        '    param('
        '        [Parameter(Mandatory)]'
        '        [string]$Path,'
        '        [Parameter(Mandatory)]'
        '        [string]$Message'
        '    )'
        '    Add-Content -LiteralPath $Path -Value ("[{0}] {1}" -f (Get-Date -Format o), $Message) -Encoding UTF8'
        '}'
        ''
        'function Append-FileToLog {'
        '    param('
        '        [Parameter(Mandatory)]'
        '        [string]$SourcePath,'
        '        [Parameter(Mandatory)]'
        '        [string]$DestinationPath,'
        '        [Parameter(Mandatory)]'
        '        [string]$Title'
        '    )'
        '    Write-LogLine -Path $DestinationPath -Message "----- $Title begin -----"'
        '    if (Test-Path -LiteralPath $SourcePath -PathType Leaf) {'
        '        $content = Get-Content -LiteralPath $SourcePath -Raw -ErrorAction SilentlyContinue'
        '        if ($null -ne $content -and $content.Length -gt 0) {'
        '            Add-Content -LiteralPath $DestinationPath -Value $content -Encoding UTF8'
        '        }'
        '    } else {'
        '        Write-LogLine -Path $DestinationPath -Message "$Title file not found: $SourcePath"'
        '    }'
        '    Write-LogLine -Path $DestinationPath -Message "----- $Title end -----"'
        '}'
        ''
        'function Remove-GeneratedFile {'
        '    param([string[]]$Path)'
        '    foreach ($item in $Path) {'
        '        if ([string]::IsNullOrWhiteSpace($item)) { continue }'
        '        Remove-Item -LiteralPath $item -Force -ErrorAction SilentlyContinue'
        '    }'
        '}'
        ''
        'function Append-TextToFile {'
        '    param('
        '        [Parameter(Mandatory)]'
        '        [string]$Path,'
        '        [Parameter(Mandatory)]'
        '        [string]$Text'
        '    )'
        '    Add-Content -LiteralPath $Path -Value $Text -Encoding UTF8'
        '}'
        ''
        'try {'
        '    if ($mode -eq "log") {'
        '        Write-LogLine -Path $mainLogPath -Message "=== $taskName elevated wrapper started ==="'
        '        Write-LogLine -Path $mainLogPath -Message "elevated identity: $([System.Security.Principal.WindowsIdentity]::GetCurrent().Name)"'
        '        Write-LogLine -Path $mainLogPath -Message "target user: $targetUser"'
        '        Write-LogLine -Path $mainLogPath -Message "target profile: $targetProfile"'
        '        Write-LogLine -Path $mainLogPath -Message "child script path: $scriptPath"'
        '        Write-LogLine -Path $mainLogPath -Message "child stdout path: $childStdoutPath"'
        '        Write-LogLine -Path $mainLogPath -Message "child stderr path: $childStderrPath"'
        '    }'
        ''
        '    if (-not (Test-Path -LiteralPath $scriptPath -PathType Leaf)) {'
        '        throw "script path does not exist: $scriptPath"'
        '    }'
        ''
        '    $childArgs = @('
        '        "-NoProfile",'
        '        "-ExecutionPolicy", "Bypass",'
        '        "-File", $scriptPath,'
        '        "-ElevatedChild",'
        '        "-TargetUser", $targetUser,'
        '        "-TargetProfilePath", $targetProfile'
        '    )'
        ''
        '    if ($mode -eq "log") {'
        '        $childArgs += @("-LogPath", $mainLogPath)'
        '    }'
        ''
        '    & powershell.exe @childArgs > $childStdoutPath 2> $childStderrPath'
        '    $exitCode = $LASTEXITCODE'
        '    if ($null -eq $exitCode) { $exitCode = 0 }'
        ''
        '    if ($mode -eq "log") {'
        '        Write-LogLine -Path $mainLogPath -Message "child exit code: $exitCode"'
        '        Append-FileToLog -SourcePath $childStdoutPath -DestinationPath $mainLogPath -Title "child stdout"'
        '        Append-FileToLog -SourcePath $childStderrPath -DestinationPath $mainLogPath -Title "child stderr"'
        '        Write-LogLine -Path $mainLogPath -Message "=== $taskName elevated wrapper finished with exit code $exitCode ==="'
        '    }'
        ''
        '    $script:ExitCode = $exitCode'
        '} catch {'
        '    if ($mode -eq "log") {'
        '        Write-LogLine -Path $mainLogPath -Message "WRAPPER ERROR: $($_.Exception.Message)"'
        '        Add-Content -LiteralPath $mainLogPath -Value ($_ | Out-String) -Encoding UTF8'
        '    } else {'
        '        Append-TextToFile -Path $childStderrPath -Text "WRAPPER ERROR: $($_.Exception.Message)"'
        '        Append-TextToFile -Path $childStderrPath -Text $_.ToString()'
        '    }'
        '    $script:ExitCode = 1'
        '} finally {'
        '    if ($mode -eq "log") {'
        '        Remove-GeneratedFile -Path @($scriptPath, $childStdoutPath, $childStderrPath)'
        '    }'
        '}'
        ''
        'exit $script:ExitCode'
    )

    [System.IO.File]::WriteAllLines($wrapperPath, $wrapper, $utf8Bom)

    if ($script:ChezmoiUacMode -eq "log") {
        Write-LogLine -Path $mainLogPath -Message "wrapper path: $wrapperPath"
        Write-LogLine -Path $mainLogPath -Message "child script path: $childScriptPath"
        Write-LogLine -Path $mainLogPath -Message "child stdout path: $childStdoutPath"
        Write-LogLine -Path $mainLogPath -Message "child stderr path: $childStderrPath"
    }

    $script:ParentExitCode = 1

    try {
        $parentStartParams = @{
            FilePath = "powershell.exe"
            ArgumentList = @(
                "-NoProfile",
                "-ExecutionPolicy", "Bypass",
                "-File", $wrapperPath
            )
            Verb = "RunAs"
            Wait = $true
            PassThru = $true
        }

        $process = Start-Process @parentStartParams

        if ($script:ChezmoiUacMode -eq "terminal") {
            Write-CapturedOutputToTerminal -StdoutPath $childStdoutPath -StderrPath $childStderrPath
        }

        if ($null -ne $process -and $process.ExitCode -ne 0) {
            if ($script:ChezmoiUacMode -eq "log") {
                Write-Warning "管理员子进程退出码为 $($process.ExitCode)，$script:ChezmoiUacTaskName 可能未执行完成。"
                Write-Warning "请查看日志: $mainLogPath"
            }

            $script:ParentExitCode = $process.ExitCode
        } else {
            if ($script:ChezmoiUacMode -eq "log") {
                Write-LogLine -Path $mainLogPath -Message "parent finished successfully."
            }

            $script:ParentExitCode = 0
        }
    } catch {
        if ($script:ChezmoiUacMode -eq "log") {
            Write-LogLine -Path $mainLogPath -Message "PARENT ERROR: $($_.Exception.Message)"
        } else {
            Write-Error "UAC 提权被取消或失败，$script:ChezmoiUacTaskName 执行失败：$($_.Exception.Message)"
        }

        $script:ParentExitCode = 1
    } finally {
        Remove-GeneratedFile -Path @(
            $wrapperPath,
            $childScriptPath,
            $childStdoutPath,
            $childStderrPath
        )
    }

    exit $script:ParentExitCode
}

Invoke-SelfElevatedIfNeeded
