# -----------------------------------------------------------------
# 基础环境与 XDG 规范
# -----------------------------------------------------------------
export XDG_DATA_HOME=$HOME/.local/share
export XDG_CONFIG_HOME=$HOME/.config
export XDG_STATE_HOME=$HOME/.local/state
export XDG_CACHE_HOME=$HOME/.cache

{{ $paths := list }}
# -----------------------------------------------------------------
# 动态 PATH 设置
# -----------------------------------------------------------------
# 优先加载 Bob 安装的 Neovim
{{- if lookPath "bob" }}
export PATH="$HOME/.local/share/bob/nvim-bin:$PATH"
{{- end }}

{{- $paths := list -}}
{{- $homeDir := .chezmoi.homeDir -}}
{{- range $_, $relPath := list "bin" "go/bin" ".cargo/bin" ".local/bin" -}}
{{    $path := joinPath $homeDir $relPath -}}
{{-   if stat $path -}}
{{-     $paths = mustAppend $paths $path -}}
{{-   end -}}
{{- end -}}
{{- if $paths -}}
# 正常的家目录 bin 路径
export PATH={{ toStrings $paths | join ":" }}:$PATH
{{ end }}

# -----------------------------------------------------------------
# 行为细节控制
# -----------------------------------------------------------------
# 历史记录时间戳格式
export HISTTIMEFORMAT="%F %T "
# 禁用自动更新检查
zstyle ':zim' disable-version-check yes

# -----------------------------------------------------------------
# 插件参数配置 (必须在 Zim 加载前定义)
# -----------------------------------------------------------------
# [fzf-tab]
# 给补全加上分组标签
zstyle ':completion:*:descriptions' format '[%d]'
# 补全列表着色（使用系统的 LS_COLORS）
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
# 强制不显示原始补全菜单，交给 fzf-tab
zstyle ':completion:*' menu no
# 预览目录内容 (使用 eza)
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
# 接受建议的快捷键设为 Tab
zstyle ':fzf-tab:*' fzf-flags --bind=tab:accept

# FZF-TAB 配色调整
# -----------------------------------------------------------------
# 补全组标题颜色
zstyle ':completion:*:*:descriptions' format $'[ %d ]'
# 选中条目的色彩 (与 FZF 保持一致)
# zstyle ':fzf-tab:*' fzf-flags --color=prompt:#CBA6F7,hl:#F38BA8,hl+:#F38BA8,pointer:#F5E0DC,info:#89DCEB --bind=tab:accept
# --color: 设置 prompt, hl(匹配高亮), pointer(选中箭头), info(信息区)
# --bind: 设置 Tab 键为选中，并添加反转视图 (fzf 风格)
zstyle ':fzf-tab:*' fzf-flags \
    --reverse \
    --pointer="➜ " \
    --bind=tab:accept \
    --color=prompt:#CBA6F7,hl:#F38BA8,hl+:#F38BA8,pointer:#F5E0DC,info:#89DCEB \
    # --color=bg+:#45475A,fg+:#CDD6F4
# 不同的补全组显示不同的颜色
zstyle ':fzf-tab:*' group-colors \
    $'\e[38;2;243;139;168m' \
    $'\e[38;2;166;227;161m' \
    $'\e[38;2;249;226;175m' \
    $'\e[38;2;137;180;250m' \
    $'\e[38;2;203;166;247m' \
    $'\e[38;2;148;226;213m'
# 切换补全分组
zstyle ':fzf-tab:*' switch-group '<' '>'

# [zsh-autosuggestions]
# 配置灰色提示的颜色：fg=8 表示浅灰色
export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=8"
# 增加补全策略：历史记录与补全系统
export ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# -----------------------------------------------------------------
# 3. 初始化 Zimfw 框架
# -----------------------------------------------------------------
export ZIM_HOME="$HOME/.zim"
if [[ ! ${ZIM_HOME}/init.zsh -nt ${ZIM_CONFIG_FILE:-${ZDOTDIR:-${HOME}}/.zimrc} ]]; then
  source ${ZIM_HOME}/zimfw.zsh init -q
fi
source ${ZIM_HOME}/init.zsh

# -----------------------------------------------------------------
# 4. 后置配置 (必须在 Zim 加载后定义)
# -----------------------------------------------------------------
# [Vi 模式与按键绑定]
# 开启 Vi 模式
bindkey -v
# 采纳建议的快捷键
bindkey '\ea' autosuggest-accept
# 撤销快捷键
bindkey '^Z' undo

# [zsh-syntax-highlighting 配色]
typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[command]='fg=#89b4fa'          # Blue
ZSH_HIGHLIGHT_STYLES[alias]='fg=#89b4fa'            # Blue
ZSH_HIGHLIGHT_STYLES[function]='fg=#89b4fa'         # Blue
ZSH_HIGHLIGHT_STYLES[builtin]='fg=#f9e2af'          # Yellow
ZSH_HIGHLIGHT_STYLES[keyword]='fg=#cba6f7'          # Mauve
ZSH_HIGHLIGHT_STYLES[string]='fg=#a6e3a1'           # Green
ZSH_HIGHLIGHT_STYLES[variable]='fg=#f9e2af'         # Yellow
ZSH_HIGHLIGHT_STYLES[comment]='fg=#6c7086'          # Overlay0
ZSH_HIGHLIGHT_STYLES[operator]='fg=#89dceb'         # Sky
ZSH_HIGHLIGHT_STYLES[parameter]='fg=#b4befe'        # Lavender
ZSH_HIGHLIGHT_STYLES[path]='fg=#94e2d5'             # Teal
ZSH_HIGHLIGHT_STYLES[error]='fg=#f38ba8'            # Red


# [Starship 提示符]
{{- if lookPath "starship" }}
eval "$(starship init zsh)"
{{- end }}

# -----------------------------------------------------------------
# 别名、函数与工具
# -----------------------------------------------------------------
setopt autocd
setopt histignorespace

# 自动重绘 fastfetch
cls() {
    command clear
    {{- if lookPath "fastfetch" }}
    # 检查 $NVIM 是否为空（不处于 Neovim 内部）且终端是交互式的
    if [[ -z "$NVIM" && -t 1 ]]; then
        fastfetch -c "$HOME/.config/fastfetch/config.jsonc"
    fi
    {{- end }}
}

alias clear='cls'

{{- if lookPath "eza" }}
# eza 别名配置

unalias ls 2> /dev/null
unalias ll 2> /dev/null
unalias la 2> /dev/null

# 基础 ls：只带图标
alias ls='eza --icons'
# ll: 长格式，包含大小(h)和精确时间格式
alias ll='eza -l -h --icons --time-style "+%Y-%m-%d %H:%M:%S"'
# la: 显示隐藏文件(a)
alias la='eza -l -h -a --icons --time-style "+%Y-%m-%d %H:%M:%S"'
# lg: 显示 Git 状态
alias lg='eza -l -h -a --git --icons --time-style "+%Y-%m-%d %H:%M:%S"'
# tree: 树状图
alias tree='eza -T --icons'
{{- else }}
# 如果没装 eza，退回到原生 ls
alias ls='ls --color=auto'
alias ll='ls -lh --color=auto'
alias la='ls -lAh --color=auto'
{{- end }}

{{ if lookPath "yazi" }}
# Yazi 协同跳转
yy() {
  local tmpfile="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi "$@" --cwd-file="$tmpfile"
  if [ -s "$tmpfile" ]; then
    local dir="$(cat "$tmpfile")"
    if [ -d "$dir" ] &&[ "$dir" != "$PWD" ]; then
      cd -- "$dir"
    fi
  fi
  rm -f "$tmpfile" > /dev/null 2>&1
}
{{ end }}

{{ if lookPath "zoxide" -}}
# Zoxide
eval "$(zoxide init zsh)"
alias cd='z'
  {{- if lookPath "yazi" }}
zy() {
  local dest
  dest=$(zoxide query -l | fzf --height 40% --reverse)
  if [[ -n "$dest" ]]; then
    zoxide add "$dest"
    yy "$dest"
  fi
}
  {{- end }}
{{ end -}}

{{- if lookPath "fzf" }}
# FZF 默认选项 (Catppuccin Mocha 配色)
[ -f /usr/share/fzf/key-bindings.zsh ] && source /usr/share/fzf/key-bindings.zsh
[ -f /usr/share/fzf/completion.zsh ] && source /usr/share/fzf/completion.zsh
export FZF_DEFAULT_OPTS=" \
--color=bg+:#313244,bg:#1E1E2E,spinner:#F5E0DC,hl:#F38BA8 \
--color=fg:#CDD6F4,header:#F38BA8,info:#CBA6F7,pointer:#F5E0DC \
--color=marker:#B4BEFE,fg+:#CDD6F4,prompt:#CBA6F7,hl+:#F38BA8 \
--color=selected-bg:#45475A \
--color=border:#6C7086,label:#CDD6F4"
{{- end }}

{{ if lookPath "tv" }}
# television 初始化
eval "$(tv init zsh)"
{{ end }}

{{ if .personal -}}
# -----------------------------------------------------------------
# 密钥与私有配置 (基于 .personal 变量)
# -----------------------------------------------------------------

# 只有在个人设备上时才加载这些 Token
{{ if .github_token -}}
export GITHUB_ACCESS_TOKEN={{ .github_token | quote }}
export CHEZMOI_GITHUB_ACCESS_TOKEN={{ .github_token | quote }}
export GITHUB_TOKEN={{ .github_token | quote }}
{{ end -}}
{{ end -}}

{{ if lookPath "bob" -}}
export PATH="$HOME/.local/share/bob/nvim-bin:$PATH"
{{ end -}}

# 启动时执行一次 fastfetch
{{- if lookPath "fastfetch" }}
# 启动终端时自动执行一次 fastfetch
cls
{{- end }}

{{- /* vim: set filetype=zsh: */}}
