# -----------------------------------------------------------------
# 基础环境与 XDG 规范
# -----------------------------------------------------------------
export XDG_DATA_HOME=$HOME/.local/share
export XDG_CONFIG_HOME=$HOME/.config
export XDG_STATE_HOME=$HOME/.local/state
export XDG_CACHE_HOME=$HOME/.cache

# P10k 即时响应 (必须最靠前)
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

{{ $paths := list }}
# -----------------------------------------------------------------
# 动态 PATH 设置
# -----------------------------------------------------------------
# 优先加载 Bob 安装的 Neovim
export PATH="$HOME/.local/share/bob/nvim-bin:$PATH"

# 正常的家目录 bin 路径
{{- $paths := list -}}
{{- $homeDir := .chezmoi.homeDir -}}
{{- range $_, $relPath := list "bin" "go/bin" ".cargo/bin" ".local/bin" -}}
{{    $path := joinPath $homeDir $relPath -}}
{{-   if stat $path -}}
{{-     $paths = mustAppend $paths $path -}}
{{-   end -}}
{{- end -}}
{{- if $paths -}}
export PATH={{ toStrings $paths | join ":" }}:$PATH
{{ end }}

# -----------------------------------------------------------------
# 插件前置处理 (zsh-completions)
# -----------------------------------------------------------------
# 必须在 Oh My Zsh 启动（compinit）之前将路径加入 fpath
if [ -d /usr/share/zsh/site-functions ]; then
  fpath=(/usr/share/zsh/site-functions $fpath)
fi

# -----------------------------------------------------------------
# Oh My Zsh 设置
# -----------------------------------------------------------------
export ZSH=$HOME/.oh-my-zsh
# 主题
ZSH_THEME="powerlevel10k/powerlevel10k"
# 区分大小写的补全
CASE_SENSITIVE="true"
# 禁用自动更新检查
DISABLE_AUTO_UPDATE="true"
# 历史记录时间戳格式
HIST_STAMPS="yyyy-mm-dd"
# 禁用安全检查
ZSH_DISABLE_COMPFIX=true

# 这里只写存在于 $ZSH/plugins 或 $ZSH_CUSTOM/plugins 里的插件
# 注意：fzf-tab 必须在 git 之后，且在 autosuggestions 之前
plugins=(git fzf-tab)

source $ZSH/oh-my-zsh.sh

# -----------------------------------------------------------------
# fzf-tab 自定义设置 (在加载后立即配置)
# -----------------------------------------------------------------
# 给补全加上分组标签
zstyle ':completion:*:descriptions' format '[%d]'
# 补全列表着色（使用系统的 LS_COLORS）
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
# 强制不显示原始补全菜单，交给 fzf-tab
zstyle ':completion:*' menu no
# 预览目录内容 (使用 eza)
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
# 接受建议的快捷键设为 Tab
zstyle ':fzf-tab:*' fzf-flags --bind=tab:accept

# -----------------------------------------------------------------
# 加载系统级插件 (pacman 安装的插件)
# -----------------------------------------------------------------

# [zsh-autosuggestions] - 灰色历史命令提示
if [ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
    source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
    # 配置灰色提示的颜色：fg=8 表示浅灰色，可以根据需要调整
    export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=8"
    # 快捷键：按 Ctrl+Space 或 方向键右 采纳建议
fi

# [zsh-syntax-highlighting] - 必须最后加载
if [ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
    source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# -----------------------------------------------------------------
# 用户自定义别名与函数
# -----------------------------------------------------------------
setopt autocd
setopt histignorespace
alias cls='clear'

{{ if lookPath "zoxide" -}}
# Zoxide
eval "$(zoxide init zsh)"
alias cd='z'
  {{- if lookPath "yazi" }}
zy() {
  local dest
  dest=$(zoxide query -l | fzf --height 40% --reverse)
  if [[ -n "$dest" ]]; then
    zoxide add "$dest"
    cd "$dest"
  fi
}
  {{- end }}
{{ end -}}

{{ if lookPath "yazi" }}
# Yazi 协同跳转
yy() {
  local tmpfile="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi "$@" --cwd-file="$tmpfile"
  if [ -s "$tmpfile" ]; then
    local dir="$(cat "$tmpfile")"
    if [ -d "$dir" ] && [ "$dir" != "$PWD" ]; then
      cd -- "$dir"
    fi
  fi
  rm -f "$tmpfile" > /dev/null 2>&1
}
{{ end }}

# FZF 默认配置
[ -f /usr/share/fzf/key-bindings.zsh ] && source /usr/share/fzf/key-bindings.zsh
[ -f /usr/share/fzf/completion.zsh ] && source /usr/share/fzf/completion.zsh

{{ if .personal -}}
# -----------------------------------------------------------------
# 密钥与私有配置 (基于 .personal 变量)
# -----------------------------------------------------------------

# 只有在个人设备上且已解锁 Bitwarden 时才加载这些 Token
{{   $bw_item := (bitwarden "item" "GitHubApiToken") -}}
export GITHUB_ACCESS_TOKEN={{ $bw_item.login.password | quote }}
export CHEZMOI_GITHUB_ACCESS_TOKEN={{ $bw_item.login.password | quote }}
export GITHUB_TOKEN={{ $bw_item.login.password | quote }}
{{ end -}}

{{ if lookPath "bob" -}}
export PATH="$HOME/.local/share/bob/nvim-bin:$PATH"
{{ end -}}

{{ if lookPath "nvim" -}}
# -----------------------------------------------------------------
# 编辑器与 P10k 配置
# -----------------------------------------------------------------
export EDITOR=nvim
{{ else -}}
export EDITOR=vim
{{ end -}}

[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

{{- /* vim: set filetype=zsh: */}}
