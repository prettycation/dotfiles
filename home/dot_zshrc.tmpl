# -----------------------------------------------------------------
# 基础环境与 XDG 规范
# -----------------------------------------------------------------
export XDG_DATA_HOME=$HOME/.local/share
export XDG_CONFIG_HOME=$HOME/.config
export XDG_STATE_HOME=$HOME/.local/state
export XDG_CACHE_HOME=$HOME/.cache

# P10k 即时响应 (必须最靠前)
# if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
#   source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
# fi

{{ $paths := list }}
# -----------------------------------------------------------------
# 动态 PATH 设置
# -----------------------------------------------------------------
# 优先加载 Bob 安装的 Neovim
{{- if lookPath "bob" }}
export PATH="$HOME/.local/share/bob/nvim-bin:$PATH"
{{- end }}

{{- $paths := list -}}
{{- $homeDir := .chezmoi.homeDir -}}
{{- range $_, $relPath := list "bin" "go/bin" ".cargo/bin" ".local/bin" -}}
{{    $path := joinPath $homeDir $relPath -}}
{{-   if stat $path -}}
{{-     $paths = mustAppend $paths $path -}}
{{-   end -}}
{{- end -}}
{{- if $paths -}}
# 正常的家目录 bin 路径
export PATH={{ toStrings $paths | join ":" }}:$PATH
{{ end }}

# -----------------------------------------------------------------
# 插件前置处理 (zsh-completions)
# -----------------------------------------------------------------
# 必须在 Oh My Zsh 启动（compinit）之前将路径加入 fpath
if [ -d /usr/share/zsh/site-functions ]; then
  fpath=(/usr/share/zsh/site-functions $fpath)
fi

# -----------------------------------------------------------------
# Oh My Zsh 设置
# -----------------------------------------------------------------
export ZSH=$HOME/.oh-my-zsh
# 主题
# ZSH_THEME="powerlevel10k/powerlevel10k"
ZSH_THEME=""
# 区分大小写的补全
CASE_SENSITIVE="true"
# 禁用自动更新检查
DISABLE_AUTO_UPDATE="true"
# 历史记录时间戳格式
HIST_STAMPS="yyyy-mm-dd"
# 禁用安全检查
ZSH_DISABLE_COMPFIX=true

# 这里只写存在于 $ZSH/plugins 或 $ZSH_CUSTOM/plugins 里的插件
# 注意：fzf-tab 必须在 git 之后，且在 autosuggestions 之前
plugins=(git fzf-tab)

source $ZSH/oh-my-zsh.sh

{{- if lookPath "starship" }}
eval "$(starship init zsh)"
{{- end }}

# -----------------------------------------------------------------
# fzf-tab 自定义设置 (在加载后立即配置)
# -----------------------------------------------------------------
# 给补全加上分组标签
zstyle ':completion:*:descriptions' format '[%d]'
# 补全列表着色（使用系统的 LS_COLORS）
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
# 强制不显示原始补全菜单，交给 fzf-tab
zstyle ':completion:*' menu no
# 预览目录内容 (使用 eza)
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
# 接受建议的快捷键设为 Tab
zstyle ':fzf-tab:*' fzf-flags --bind=tab:accept

# -----------------------------------------------------------------
# zsh-readline (历史预测 ListView)
# -----------------------------------------------------------------
# 路径检查：优先使用系统级路径，如果不存在，则检查 Oh My Zsh custom 路径
if [ -f /usr/share/zsh/plugins/zsh-readline/zsh-readline.plugin.zsh ] || [ -f "$ZSH_CUSTOM/plugins/zsh-readline/zsh-readline.plugin.zsh" ]; then
    
    # 1. 配置参数 (必须在 source 之前定义)
    export ZSH_READLINE_MAX_PREDICTIONS=10
    export ZSH_READLINE_MIN_INPUT=1
    export ZSH_READLINE_REMOVE_DUPLICATE_HISTORY_ENTRIES=1

    # 2. 确保 History 设置
    setopt SHARE_HISTORY
    HISTSIZE=10000
    SAVEHIST=10000

    # 3. 加载插件
    if [ -f /usr/share/zsh/plugins/zsh-readline/zsh-readline.plugin.zsh ]; then
        source /usr/share/zsh/plugins/zsh-readline/zsh-readline.plugin.zsh
    else
        source "$ZSH_CUSTOM/plugins/zsh-readline/zsh-readline.plugin.zsh"
    fi
fi

# -----------------------------------------------------------------
# 加载系统级插件 (pacman 安装的插件)
# -----------------------------------------------------------------

# [zsh-autosuggestions] - 灰色历史命令提示
if [ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
    source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
    # 配置灰色提示的颜色：fg=8 表示浅灰色，可以根据需要调整
    export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=8"
    # 快捷键：按 Ctrl+Space 或 方向键右 采纳建议
    # 增加补全策略：历史记录与补全系统
    export ZSH_AUTOSUGGEST_STRATEGY=(history completion)
fi

# [zsh-syntax-highlighting] - 必须最后加载
if [ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
    source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
    
    # --- 添加: 语法高亮配色 (Catppuccin Mocha) ---
    typeset -A ZSH_HIGHLIGHT_STYLES
    ZSH_HIGHLIGHT_STYLES[command]='fg=#89b4fa'          # Blue
    ZSH_HIGHLIGHT_STYLES[alias]='fg=#89b4fa'            # Blue
    ZSH_HIGHLIGHT_STYLES[function]='fg=#89b4fa'         # Blue
    ZSH_HIGHLIGHT_STYLES[builtin]='fg=#f9e2af'          # Yellow
    ZSH_HIGHLIGHT_STYLES[keyword]='fg=#cba6f7'          # Mauve
    ZSH_HIGHLIGHT_STYLES[string]='fg=#a6e3a1'           # Green
    ZSH_HIGHLIGHT_STYLES[variable]='fg=#f9e2af'         # Yellow
    ZSH_HIGHLIGHT_STYLES[comment]='fg=#6c7086'          # Overlay0
    ZSH_HIGHLIGHT_STYLES[operator]='fg=#89dceb'         # Sky
    ZSH_HIGHLIGHT_STYLES[parameter]='fg=#b4befe'        # Lavender
    ZSH_HIGHLIGHT_STYLES[path]='fg=#94e2d5'             # Teal
    ZSH_HIGHLIGHT_STYLES[error]='fg=#f38ba8'            # Red
fi

# -----------------------------------------------------------------
# Vi 模式与终端体验 (对应 PSReadLine)
# -----------------------------------------------------------------
# 启用 Vi 模式
bindkey -v

# 光标形状切换 (Command=方块, Insert=竖线)
function zle-keymap-select() {
    case $KEYMAP in
        vicmd)      echo -ne "\e[1 q" ;;
        viins|main) echo -ne "\e[5 q" ;;
    esac
}
zle -N zle-keymap-select

# 确保每次新命令行时光标重置为竖线
function zle-line-init() {
    echo -ne "\e[5 q"
}
zle -N zle-line-init

# 修复 Vi 模式下的退格键行为
bindkey "^?" backward-delete-char
bindkey "^H" backward-delete-char

# 上下箭头历史搜索 (对应 PSReadLine 的 HistorySearchBackward/Forward)
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward
# Vi 模式(命令模式)下的 k 和 j 同样支持搜索
bindkey -M vicmd 'k' history-search-backward
bindkey -M vicmd 'j' history-search-forward

# 撤销快捷键 (Ctrl+z)
bindkey '^Z' undo

# -----------------------------------------------------------------
# 用户自定义别名与函数
# -----------------------------------------------------------------
setopt autocd
setopt histignorespace

# 自动重绘 fastfetch
cls() {
    command clear
    {{- if lookPath "fastfetch" }}
    # 检查 $NVIM 是否为空（不处于 Neovim 内部）且终端是交互式的
    if [[ -z "$NVIM" && -t 1 ]]; then
        fastfetch -c "$HOME/.config/fastfetch/config.jsonc"
    fi
    {{- end }}
}

alias clear='cls'

{{- if lookPath "eza" }}
# eza 别名配置

unalias ls 2> /dev/null
unalias ll 2> /dev/null
unalias la 2> /dev/null

# 基础 ls：只带图标
alias ls='eza --icons'
# ll: 长格式，包含大小(h)和精确时间格式
alias ll='eza -l -h --icons --time-style "+%Y-%m-%d %H:%M:%S"'
# la: 显示隐藏文件(a)
alias la='eza -l -h -a --icons --time-style "+%Y-%m-%d %H:%M:%S"'
# lg: 显示 Git 状态
alias lg='eza -l -h -a --git --icons --time-style "+%Y-%m-%d %H:%M:%S"'
# tree: 树状图
alias tree='eza -T --icons'
{{- else }}
# 如果没装 eza，退回到原生 ls
alias ls='ls --color=auto'
alias ll='ls -lh --color=auto'
alias la='ls -lAh --color=auto'
{{- end }}

{{ if lookPath "yazi" }}
# Yazi 协同跳转
yy() {
  local tmpfile="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi "$@" --cwd-file="$tmpfile"
  if [ -s "$tmpfile" ]; then
    local dir="$(cat "$tmpfile")"
    if [ -d "$dir" ] &&[ "$dir" != "$PWD" ]; then
      cd -- "$dir"
    fi
  fi
  rm -f "$tmpfile" > /dev/null 2>&1
}
{{ end }}

{{ if lookPath "zoxide" -}}
# Zoxide
eval "$(zoxide init zsh)"
alias cd='z'
  {{- if lookPath "yazi" }}
zy() {
  local dest
  dest=$(zoxide query -l | fzf --height 40% --reverse)
  if [[ -n "$dest" ]]; then
    zoxide add "$dest"
    yy "$dest"
  fi
}
  {{- end }}
{{ end -}}

# FZF 默认选项 (Catppuccin Mocha 配色)
{{- if lookPath "fzf" }}[ -f /usr/share/fzf/key-bindings.zsh ] && source /usr/share/fzf/key-bindings.zsh[ -f /usr/share/fzf/completion.zsh ] && source /usr/share/fzf/completion.zsh
export FZF_DEFAULT_OPTS=" \
--color=bg+:#313244,bg:#1E1E2E,spinner:#F5E0DC,hl:#F38BA8 \
--color=fg:#CDD6F4,header:#F38BA8,info:#CBA6F7,pointer:#F5E0DC \
--color=marker:#B4BEFE,fg+:#CDD6F4,prompt:#CBA6F7,hl+:#F38BA8 \
--color=selected-bg:#45475A \
--color=border:#6C7086,label:#CDD6F4"
{{- end }}

