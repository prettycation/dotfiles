# --- 1. 基础设置 ---
port: 7890
socks-port: 7891
mixed-port: 7890 # HTTP/SOCKS5 混合端口
allow-lan: true # 允许局域网连接
mode: rule # 规则模式
log-level: info
ipv6: false
external-controller: 127.0.0.1:9090 # API 端口
{{- if .mihomo_secret }}
secret: {{ .mihomo_secret }}
{{- else}}
secret: {{ (bitwarden "item" "mihomo-secret").login.password }} # API 密钥 (留空则无)
{{- end}}

# --- 2. DNS 配置 (Fake-IP) ---
dns:
  enable: true
  listen: :53
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
  nameserver:
    - https://dns.alidns.com/dns-query
    - https://doh.pub/dns-query
  fallback:
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query
  nameserver-policy:
    "geosite:cn,private":
      [https://doh.pub/dns-query, https://dns.alidns.com/dns-query]
    "geosite:google,youtube,telegram,gfw":
      [https://1.1.1.1/dns-query, https://8.8.8.8/dns-query]

# --- 3. 代理提供商 (Proxy Providers) ---
proxy-providers:
  Airport:
    type: http
    {{- if .airport_sub }}
    url: {{ .airport_sub }}
    {{- else }}
    url: {{ (bitwarden "item" "airport-sub").login.password}}
    {{- end }}
    interval: 3600
    path: ./airport.yaml
    health-check:
      enable: true
      interval: 300
      url: http://www.gstatic.com/generate_204

# --- 4. 策略组 (Proxy Groups) ---
proxy-groups:
  # 4.1 核心选择组
  - name: 🔰 节点选择
    type: select
    proxies:
      - ♻️ 故障转移
      - 🇭🇰 香港
      - 🇹🇼 台湾
      - 🇸🇬 新加坡
      - 🇯🇵 日本
      - 🇺🇸 美国
      - DIRECT

  # 4.2 自动故障转移
  - name: ♻️ 故障转移
    type: fallback
    url: http://www.gstatic.com/generate_204
    interval: 300
    use:
      - Airport # 使用上面定义的 Airport 提供商
    # 过滤掉不想用的节点
    filter: "(?i)^(?!.*(官网|剩余|到期|重置|套餐)).*"

  # 4.3 地区分组 (利用正则筛选)
  - name: 🇭🇰 香港
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 50
    use:
      - Airport
    filter: "(?i)HK|Hong|Kong|香港" # 👈 正则筛选香港节点

  - name: 🇹🇼 台湾
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 50
    use:
      - Airport
    filter: "(?i)TW|Taiwan|台湾|Taipei"

  - name: 🇸🇬 新加坡
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 50
    use:
      - Airport
    filter: "(?i)SG|Singapore|新加坡|狮城"

  - name: 🇯🇵 日本
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 50
    use:
      - Airport
    filter: "(?i)JP|Japan|日本|Tokyo"

  - name: 🇺🇸 美国
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 50
    use:
      - Airport
    filter: "(?i)US|USA|United|States|美国"

  # 4.4 特殊功能组
  - name: Ⓜ️ 微软服务
    type: select
    proxies:
      - 🔰 节点选择
      - DIRECT

  - name: 🍎 苹果服务
    type: select
    proxies:
      - 🔰 节点选择
      - DIRECT

  - name: 🔞 限定区域 (No JP)
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    use:
      - Airport
    # 排除日本和中国节点 (E-Hentai 专用)
    filter: "(?i)^(?!.*(JP|Japan|日本|CN|China)).*"

  - name: 🐟 漏网之鱼
    type: select
    proxies:
      - 🔰 节点选择
      - DIRECT

