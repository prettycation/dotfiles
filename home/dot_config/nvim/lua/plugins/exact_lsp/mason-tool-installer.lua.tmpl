{{- $hasPwsh := lookPath "pwsh" -}}
{{- $hasWindowsPS := lookPath "powershell" -}}

{{- if or $hasPwsh $hasWindowsPS }}
return {
  {
    "WhoIsSethDaniel/mason-tool-installer.nvim",
    optional = true,
    opts = function(_, opts)
      opts.ensure_installed = opts.ensure_installed or {}

      -- {{- if or $hasPwsh $hasWindowsPS }}
      -- 如果系统里存在 PowerShell，让 Mason 自动确保 PSES 已安装
      -- powershell.nvim 本身不会自动下载 PowerShell Editor Services，
      -- 所以这里交给 mason-tool-installer 负责自动补齐。
      if not vim.tbl_contains(opts.ensure_installed, "powershell-editor-services") then
        table.insert(opts.ensure_installed, "powershell-editor-services")
      end
      -- {{- end }}
    end,
  },
}
{{- end }}
{{/* vim: set ft=lua.chezmoitemplate: */}}
