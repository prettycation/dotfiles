{{- $hasFd := lookPath "fd" -}}
{{- $hasPoetry := lookPath "poetry" -}}
{{- $hasUv := lookPath "uv" -}}
{{- $hasConda := lookPath "conda" -}}
{{- $isWindows := eq .chezmoi.os "windows" -}}

return {
  {
    "linux-cultist/venv-selector.nvim",
    cmd = { "VenvSelect", "VenvSelectCached" },
    opts = function(_, opts)
      -- 基础配置
      opts.options = opts.options or {}
      opts.options.debug = false
      opts.options.notify_user_on_venv_activation = true

      -- 环境名称显示逻辑 (通用)
      opts.options.on_telescope_result_callback = function(filename)
        -- 统一路径分隔符，防止 Windows 反斜杠干扰
        filename = filename:gsub("\\", "/")

        -- 获取 python 所在的目录
        local parent_path = vim.fn.fnamemodify(filename, ":h")
        local parent_dir = vim.fn.fnamemodify(parent_path, ":t")

        -- 如果是在 Scripts (Win) 或 bin (Unix)，往上一层获取环境名
        if parent_dir == "Scripts" or parent_dir == "bin" then
          local grand_parent_path = vim.fn.fnamemodify(parent_path, ":h")
          local env_name = vim.fn.fnamemodify(grand_parent_path, ":t")

          -- UV 逻辑: .venv 目录下显示项目名
          if env_name == ".venv" then
            local project_path = vim.fn.fnamemodify(grand_parent_path, ":h")
            local project_name = vim.fn.fnamemodify(project_path, ":t")
            return project_name .. " (uv)"
          end

          return env_name -- 返回 Poetry 的 "project-hash" 或普通 venv 名字
        end

        -- Anaconda 结构处理
        return parent_dir
      end

      -- 1. 只有 fd 在 PATH 中时，才生成基于 fd 的自定义搜索命令；
      -- 2. 只有 poetry / uv / conda 在 PATH 中时，才生成对应生态的搜索项；
      -- 3. 如果 fd 不存在，就不覆盖插件默认搜索策略，避免生成无效命令。
      {{- if $hasFd }}
      opts.search = {
        {{- if $isWindows }}

        {{- if $hasConda }}
        anaconda_envs = {
          command = "fd -u -F python.exe E:\\anaconda\\envs --max-depth 2 --full-path --color never -E Lib",
          type = "anaconda",
        },
        anaconda_base = {
          command = "fd -u -F python.exe E:\\anaconda --max-depth 1 --full-path --color never -E Lib",
          type = "anaconda",
        },
        {{- end }}

        -- Windows 默认的 .venv 搜索
        cwd = {
          command = "fd -u -F python.exe --max-depth 3 --color never",
        },

        {{- else }}

        -- 1. 搜索当前工作目录下的 .venv (通用)
        cwd = {
          command = "fd -H -F python --max-depth 3 --color never -E .git",
        },

        {{- if $hasPoetry }}
        -- 2. 搜索 Poetry 虚拟环境
        poetry = {
          command = "fd -u -F python {{ if eq .chezmoi.os "darwin" }}~/Library/Caches/pypoetry/virtualenvs{{ else }}~/.cache/pypoetry/virtualenvs{{ end }} --max-depth 2 --color never",
        },
        {{- end }}

        {{- if $hasUv }}
        -- 3. 搜索 UV 环境
        uv = {
          command = "fd -u -F python ~/.local/share/uv/python --max-depth 2 --color never",
        },
        {{- end }}

        -- 4. 搜索系统默认虚拟环境存放点
        vms = {
          command = "fd -u -F python ~/.virtualenvs --max-depth 2 --color never",
        },

        {{- if $hasConda }}
        -- 5. 如果 Linux/Mac 也装了 Conda (可选)
        conda = {
          command = "fd -u -F python ~/anaconda3/envs --max-depth 2 --color never",
        },
        {{- end }}

        {{- end }}
      }
      {{- end }}
    end,
  },
}
{{/* vim: set ft=lua.chezmoitemplate: */}}
