{{- $isWindows := eq .chezmoi.os "windows" -}}

{{- /* Python: Windows 优先 python；Unix 优先 python3，找不到再退回 python */ -}}
{{- $pythonCmd := "" -}}
{{- if $isWindows -}}
  {{- if lookPath "python" -}}
    {{- $pythonCmd = "python" -}}
  {{- end -}}
{{- else -}}
  {{- if lookPath "python3" -}}
    {{- $pythonCmd = "python3" -}}
  {{- else if lookPath "python" -}}
    {{- $pythonCmd = "python" -}}
  {{- end -}}
{{- end -}}

{{- /* Shell: Windows 优先 nu，再退回 pwsh，最后退回 powershell；Unix 优先 zsh，再退回 sh */ -}}
{{- $shellCmd := "" -}}
{{- if $isWindows -}}
  {{- if lookPath "nu" -}}
    {{- $shellCmd = "nu" -}}
  {{- else if lookPath "pwsh" -}}
    {{- $shellCmd = "pwsh" -}}
  {{- else if lookPath "powershell" -}}
    {{- $shellCmd = "powershell" -}}
  {{- end -}}
{{- else -}}
  {{- if lookPath "zsh" -}}
    {{- $shellCmd = "zsh" -}}
  {{- else if lookPath "sh" -}}
    {{- $shellCmd = "sh" -}}
  {{- end -}}
{{- end -}}

{{- /* 其他运行时 */ -}}
{{- $hasLua := lookPath "lua" -}}

{{- /* 清屏命令 */ -}}
{{- $clearCmd := "clear" -}}
{{- if $isWindows -}}
  {{- $clearCmd = "cls" -}}
{{- end -}}

return {
  -- 1. Overseer.nvim: 在 LazyVim extra 的默认配置上追加“运行当前文件”
  {
    "stevearc/overseer.nvim",
    lazy = true,
    optional = true,
    keys = function(_, keys)
      keys[#keys + 1] = {
        "<leader>or",
        function()
          require("utils.run_file").run()
        end,
        desc = "Run Current File",
      }

      return keys
    end,
  },

  -- 2. Iron.nvim: 交互式 REPL
  {
    "Vigemus/iron.nvim",
    main = "iron.core",
    opts = function()
      local view = require("iron.view")
      local common = require("iron.fts.common")

      return {
        config = {
          -- 窗口配置：垂直分屏，占据 40% 宽度
          repl_open_cmd = view.split.vertical.botright(0.4),

          -- 语言定义
          repl_definition = {
            {{- if $pythonCmd }}
            python = {
              -- 使用 Table 格式，不能用空格拼接字符串
              command = { "{{ $pythonCmd }}", "-u" },
              format = common.bracketed_paste_python,
            },
            {{- end }}

            {{- if $hasLua }}
            lua = {
              command = { "lua" },
            },
            {{- end }}

            {{- if $shellCmd }}
            sh = {
              -- Windows 下按 nu -> pwsh -> powershell 逐级回退；
              -- Unix 下按 zsh -> sh 逐级回退。
              command = { "{{ $shellCmd }}" },
            },
            {{- end }}
          },
        },

        -- 键位映射
        -- 移除了 clear 和 exit，改在下方的 keys 中自定义实现
        keymaps = {
          toggle_repl = "<leader>ro",
          visual_send = "<leader>rs",
          send_line = "<leader>rs",
          interrupt = "<leader>ri", -- 中断运行 (Ctrl+C)
          restart_repl = "<leader>rR", -- 重启 REPL
        },

        -- 高亮配置
        highlight = {
          italic = true,
        },
      }
    end,

    -- 自定义按键绑定
    keys = {
      { "<leader>ro", desc = "Toggle REPL" },
      { "<leader>rs", mode = { "n", "v" }, desc = "Send to REPL" },
      { "<leader>ri", desc = "Interrupt REPL" },
      { "<leader>rR", desc = "Restart REPL" },

      {{- if $pythonCmd }}
      -- 【Windows 修复】自定义清屏：发送 Python 的 os.system('cls')
      {
        "<leader>rl",
        function()
          require("iron.core").send(nil, "import os; os.system('{{ $clearCmd }}')")
        end,
        desc = "Clear REPL",
      },
      {{- end }}

      -- 【Windows 修复】自定义退出：
      -- Python REPL 发送 exit()；其他 REPL 发送 exit。
      {
        "<leader>rq",
        function()
          local exit_cmd = vim.bo.filetype == "python" and "exit()" or "exit"
          require("iron.core").send(nil, exit_cmd)

          -- 延迟 200ms 关闭窗口，给 REPL 一点时间退出
          vim.defer_fn(function()
            require("iron.core").close_repl()
          end, 200)
        end,
        desc = "Quit REPL",
      },
    },
  },
}
{{/* vim: set ft=lua.chezmoitmpl: */}}
