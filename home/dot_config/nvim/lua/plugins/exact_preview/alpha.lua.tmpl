return {
  {
    "goolord/alpha-nvim",
    event = "VimEnter",
    init = false,
    opts = function()
      local dashboard = require("alpha.themes.dashboard")
      local utils = require("alpha.utils")

      local logo = [[
                                              
       ███████████           █████      ██
      ███████████             █████ 
      ████████████████ ███████████ ███   ███████
     ████████████████ ████████████ █████ ██████████████
    █████████████████████████████ █████ █████ ████ █████
  ██████████████████████████████████ █████ █████ ████ █████
 ██████  ███ █████████████████ ████ █████ █████ ████ ██████
 ██████   ██  ███████████████   ██ █████████████████
      ]]

      local header_val = vim.split(logo, "\n")

      local header_hl = {
        { { "AlphaHeader0_0", 46, 48 } },
        {
          { "AlphaHeader1_0", 7, 22 },
          { "AlphaHeader1_1", 33, 40 },
          { "AlphaHeader1_2", 40, 50 },
        },
        {
          { "AlphaHeader2_0", 6, 21 },
          { "AlphaHeader2_1", 33, 45 },
        },
        {
          { "AlphaHeader3_0", 6, 19 },
          { "AlphaHeader3_1", 19, 20 },
          { "AlphaHeader3_2", 20, 35 },
          { "AlphaHeader3_3", 35, 45 },
          { "AlphaHeader3_4", 45, 90 },
        },
        {
          { "AlphaHeader4_0", 5, 18 },
          { "AlphaHeader4_1", 18, 36 },
          { "AlphaHeader4_2", 36, 45 },
          { "AlphaHeader4_3", 45, 90 },
        },
        {
          { "AlphaHeader5_0", 4, 17 },
          { "AlphaHeader5_1", 17, 24 },
          { "AlphaHeader5_2", 24, 28 },
          { "AlphaHeader5_3", 28, 37 },
          { "AlphaHeader5_4", 37, 46 },
          { "AlphaHeader5_5", 46, 90 },
        },
        {
          { "AlphaHeader6_0", 2, 17 },
          { "AlphaHeader6_1", 17, 38 },
          { "AlphaHeader6_2", 38, 45 },
          { "AlphaHeader6_3", 46, 90 },
        },
        {
          { "AlphaHeader7_0", 1, 17 },
          { "AlphaHeader7_1", 17, 38 },
          { "AlphaHeader7_2", 38, 45 },
          { "AlphaHeader7_3", 46, 90 },
        },
        {
          { "AlphaHeader8_0", 1, 37 },
          { "AlphaHeader8_1", 37, 91 },
        },
      }

      header_hl = utils.charhl_to_bytehl(header_hl, header_val, false)

      -- 目标：
      -- N / V: 左上深 -> 右下浅
      -- eo / im: 仅 surface + shadow
      -- n / v: 保留底部阴影
      -- 阴影纵深收小
      local c = {
        -- N：整体偏暗，左上深 -> 右下浅
        n_deep1 = "#5c82b6",
        n_deep2 = "#678dc4",
        n_mid1 = "#7299d1",
        n_mid2 = "#7da4dd",
        n_light1 = "#87afe8",
        n_light2 = "#91b9f1",
        n_shadow = "#4d6c9b",

        -- eo：比 n_light2 更亮，但阴影和 N 统一
        eo_surface = "#abd1ff",
        eo_shadow = "#4d6c9b",

        -- V：整体偏暗，左上深 -> 右下浅
        v_deep1 = "#846dc3",
        v_deep2 = "#9078cf",
        v_mid1 = "#9b84da",
        v_mid2 = "#a68fe4",
        v_light1 = "#b19aee",
        v_light2 = "#bca5f6",
        v_shadow = "#695798",

        -- im：比 v_light2 更亮，但阴影和 V 统一
        im_surface = "#d0bcff",
        im_shadow = "#695798",

        -- i 的点
        dot = "#d0bcff",
      }

      -- 顶部 i 的点
      vim.api.nvim_set_hl(0, "AlphaHeader0_0", { fg = c.dot })

      -- row 1
      vim.api.nvim_set_hl(0, "AlphaHeader1_0", { fg = c.n_deep1 }) -- N 顶部最深
      vim.api.nvim_set_hl(0, "AlphaHeader1_1", { fg = c.v_deep1 }) -- V 顶部最深
      vim.api.nvim_set_hl(0, "AlphaHeader1_2", { fg = c.im_surface }) -- im 顶面

      -- row 2
      vim.api.nvim_set_hl(0, "AlphaHeader2_0", { fg = c.n_deep2 }) -- N 渐变继续
      vim.api.nvim_set_hl(0, "AlphaHeader2_1", { fg = c.v_deep2 }) -- V 渐变继续

      -- row 3
      vim.api.nvim_set_hl(0, "AlphaHeader3_0", { fg = c.n_mid1 }) -- N 渐变
      vim.api.nvim_set_hl(0, "AlphaHeader3_1", { fg = c.eo_shadow }) -- neo 内阴影切面
      vim.api.nvim_set_hl(0, "AlphaHeader3_2", { fg = c.eo_surface }) -- eo 表面
      vim.api.nvim_set_hl(0, "AlphaHeader3_3", { fg = c.v_mid1 }) -- V 渐变
      vim.api.nvim_set_hl(0, "AlphaHeader3_4", { fg = c.im_surface }) -- im 表面

      -- row 4
      vim.api.nvim_set_hl(0, "AlphaHeader4_0", { fg = c.n_mid2 }) -- N 渐变
      vim.api.nvim_set_hl(0, "AlphaHeader4_1", { fg = c.eo_surface }) -- eo 表面
      vim.api.nvim_set_hl(0, "AlphaHeader4_2", { fg = c.v_mid2 }) -- V 渐变
      vim.api.nvim_set_hl(0, "AlphaHeader4_3", { fg = c.im_surface }) -- im 表面

      -- row 5
      vim.api.nvim_set_hl(0, "AlphaHeader5_0", { fg = c.n_light1 }) -- N 渐变
      vim.api.nvim_set_hl(0, "AlphaHeader5_1", { fg = c.eo_surface }) -- eo 表面
      vim.api.nvim_set_hl(0, "AlphaHeader5_2", { fg = c.eo_shadow }) -- eo 阴影切面
      vim.api.nvim_set_hl(0, "AlphaHeader5_3", { fg = c.eo_surface }) -- eo 表面
      vim.api.nvim_set_hl(0, "AlphaHeader5_4", { fg = c.v_light1 }) -- V 渐变
      vim.api.nvim_set_hl(0, "AlphaHeader5_5", { fg = c.im_surface }) -- im 表面

      -- row 6
      vim.api.nvim_set_hl(0, "AlphaHeader6_0", { fg = c.n_light2 }) -- N 接近最浅
      vim.api.nvim_set_hl(0, "AlphaHeader6_1", { fg = c.eo_surface }) -- eo 表面
      vim.api.nvim_set_hl(0, "AlphaHeader6_2", { fg = c.v_light2 }) -- V 接近最浅
      vim.api.nvim_set_hl(0, "AlphaHeader6_3", { fg = c.im_surface }) -- im 表面

      -- row 7
      vim.api.nvim_set_hl(0, "AlphaHeader7_0", { fg = c.n_light2 }) -- n 底边亮面
      vim.api.nvim_set_hl(0, "AlphaHeader7_1", { fg = c.eo_surface }) -- eo 表面
      vim.api.nvim_set_hl(0, "AlphaHeader7_2", { fg = c.v_light2 }) -- v 底边亮面
      vim.api.nvim_set_hl(0, "AlphaHeader7_3", { fg = c.im_surface }) -- im 表面

      -- row 8
      vim.api.nvim_set_hl(0, "AlphaHeader8_0", { fg = c.n_shadow }) -- neo 底部阴影（含 n）
      vim.api.nvim_set_hl(0, "AlphaHeader8_1", { fg = c.v_shadow }) -- vim 底部阴影（含 v）

      dashboard.section.header.val = header_val
      dashboard.section.header.opts.hl = header_hl

      dashboard.section.buttons.val = {
        dashboard.button("f", "  Find file", [[<cmd> lua LazyVim.pick()() <cr>]]),
        dashboard.button("n", "  New file", [[<cmd> ene <BAR> startinsert <cr>]]),
        dashboard.button("r", "  Recent files", [[<cmd> lua LazyVim.pick("oldfiles")() <cr>]]),
        dashboard.button("g", "  Find text", [[<cmd> lua LazyVim.pick("live_grep")() <cr>]]),
        dashboard.button("c", "  Config", [[<cmd> lua LazyVim.pick.config_files()() <cr>]]),
        dashboard.button("s", "  Restore Session", [[<cmd> lua require("persistence").load() <cr>]]),
        dashboard.button("x", "  Lazy Extras", [[<cmd> LazyExtras <cr>]]),
        dashboard.button("l", "󰒲  Lazy", [[<cmd> Lazy <cr>]]),
        dashboard.button("q", "  Quit", [[<cmd> qa <cr>]]),
      }

      for _, button in ipairs(dashboard.section.buttons.val) do
        button.opts.hl = "AlphaButtons"
        button.opts.hl_shortcut = "AlphaShortcut"
      end

      dashboard.section.buttons.opts.hl = "AlphaButtons"
      dashboard.section.footer.opts.hl = "AlphaFooter"

      vim.api.nvim_set_hl(0, "AlphaButtons", { link = "Function" })
      vim.api.nvim_set_hl(0, "AlphaShortcut", { link = "Keyword" })

      -- footer 改成 Catppuccin Red
      vim.api.nvim_set_hl(0, "AlphaFooter", { fg = "#f38ba8" })

      dashboard.opts.layout[1].val = 6
      dashboard.opts.opts.noautocmd = true

      return dashboard
    end,

    config = function(_, dashboard)
      if vim.o.filetype == "lazy" then
        vim.cmd.close()
        vim.api.nvim_create_autocmd("User", {
          once = true,
          pattern = "AlphaReady",
          callback = function()
            require("lazy").show()
          end,
        })
      end

      require("alpha").setup(dashboard.opts)

      vim.api.nvim_create_autocmd("User", {
        once = true,
        pattern = "LazyVimStarted",
        callback = function()
          local stats = require("lazy").stats()
          local ms = math.floor(stats.startuptime * 100 + 0.5) / 100
          dashboard.section.footer.val = "⚡ Neovim loaded "
            .. stats.loaded
            .. "/"
            .. stats.count
            .. " plugins in "
            .. ms
            .. "ms"
          pcall(vim.cmd.AlphaRedraw)
        end,
      })

      local group = vim.api.nvim_create_augroup("AlphaDashboardTweaks", { clear = true })

      vim.api.nvim_create_autocmd("User", {
        group = group,
        pattern = "AlphaReady",
        callback = function()
          vim.opt_local.showcmd = false
          vim.opt_local.ruler = false
        end,
      })

      vim.api.nvim_create_autocmd("BufUnload", {
        group = group,
        pattern = "<buffer>",
        callback = function()
          vim.opt.showcmd = true
          vim.opt.ruler = true
        end,
      })

      -- 判断是否是 `nvim <directory>` 启动
      local function startup_dir()
        if vim.fn.argc() ~= 1 then
          return nil
        end
        local arg = vim.fn.argv(0)
        if not arg or arg == "" then
          return nil
        end
        local dir = vim.fn.fnamemodify(arg, ":p")
        local stat = vim.uv.fs_stat(dir)
        if stat and stat.type == "directory" then
          return dir
        end
      end

      -- 参考 Snacks 的做法：
      -- 先切到目标页面，再检查“启动遗留 buffer”是否已经不在任何窗口里。
      -- 如果不在了，就删掉它；这样不会残留一个空白普通 buffer。
      local function cleanup_buf_if_hidden(buf)
        if not vim.api.nvim_buf_is_valid(buf) then
          return
        end
        if #vim.fn.win_findbuf(buf) == 0 then
          pcall(vim.api.nvim_buf_delete, buf, { force = true })
        end
      end

      -- `nvim .` 时：
      -- 1. 先把 cwd 切到目录
      -- 2. 打开 Alpha dashboard
      -- 3. 再删除已经脱离窗口的启动 buffer
      local dir = startup_dir()
      if dir then
        vim.schedule(function()
          local startup_buf = vim.api.nvim_get_current_buf()

          vim.cmd.cd(vim.fn.fnameescape(dir))
          vim.cmd.Alpha()

          -- 等 Alpha 完成切换后，再清理旧 buffer
          vim.schedule(function()
            cleanup_buf_if_hidden(startup_buf)
          end)
        end)
      end
    end,
  },
}
