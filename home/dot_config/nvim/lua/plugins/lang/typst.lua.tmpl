{{- $hasTinymist := lookPath "tinymist" -}}
{{- $hasTypstyle := lookPath "typstyle" -}}
{{- $hasWebsocat := lookPath "websocat" -}}

return {
  -- Typst Preview：只在需要时显式指定系统已有二进制
  {
    "chomosuke/typst-preview.nvim",
    optional = true,
    {{- if or $hasTinymist $hasWebsocat }}
    opts = {
      dependencies_bin = {
        {{- if $hasTinymist }}
        -- 显式告诉 typst-preview 使用系统里的 tinymist。
        tinymist = "tinymist",
        {{- end }}
        {{- if $hasWebsocat }}
        -- 如果系统里已经有 websocat，也直接复用系统版本。
        websocat = "websocat",
        {{- end }}
      },
    },
    {{- end }}
  },

  -- Conform：只在 typstyle 存在时，显式指定 typst 的 formatter
  {
    "stevearc/conform.nvim",
    optional = true,
    opts = function(_, opts)
      opts.formatters_by_ft = opts.formatters_by_ft or {}

      {{- if $hasTypstyle }}
      -- 只有在 typstyle 存在时，才把 typst 的格式化器显式收敛到 typstyle。

      -- lsp_format = "prefer" 的含义：
      -- - 优先使用这里声明的 formatter
      -- - 必要时仍允许走 LSP 侧的格式化能力
      opts.formatters_by_ft.typst = { "typstyle", lsp_format = "prefer" }
      {{- end }}
    end,
  },
}
