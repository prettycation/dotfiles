{{- $hasCode := lookPath "code" -}}

{{- $cond := "" -}}

{{- if $hasCode }}
{{- $cond = "-- 在 vscode 中加载\n\t\tcond = true,\n\t\t"}}
{{- end }}
return {
  {
    "mg979/vim-visual-multi",
    {{ $cond -}}
    branch = "master",
    event = "BufReadPost", -- 打开文件后加载
    init = function()
      -- 开启鼠标支持 (按住 Ctrl + 鼠标左键点击也可添加光标)
      vim.g.VM_mouse_mappings = 1
      vim.g.VM_maps = {
        ["Find Under"] = "<C-n>", -- 选中光标下的单词，再次按选中下一个
        ["Find Subword Under"] = "<C-n>", -- 选中光标下的子词
      }
    end,
  },
}
{{/* vim: set filetype=lua.chezmoitmpl: */}}
