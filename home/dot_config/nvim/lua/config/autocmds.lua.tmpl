-- Autocmds are automatically loaded on the VeryLazy event
-- Default autocmds that are always set: https://github.com/LazyVim/LazyVim/blob/main/lua/lazyvim/config/autocmds.lua
--
-- Add any additional autocmds here
-- with `vim.api.nvim_create_autocmd`
--
-- Or remove existing autocmds by their group name (which is prefixed with `lazyvim_` for the defaults)
-- e.g. vim.api.nvim_del_augroup_by_name("lazyvim_wrap_spell")

vim.api.nvim_create_autocmd("FileType", {
  pattern = { "markdown", "typst", "text", "gitcommit" },

  callback = function()
    -- 禁用拼写检查
    vim.opt_local.spell = false
  end,
})

-- 禁用 chezmoi Lua 模板文件的自动格式化
-- 避免保存时把 {{/* ... */}} 这类模板语法交给 Lua formatter 处理
vim.api.nvim_create_autocmd("FileType", {
  pattern = { "lua.chezmoitmpl" },
  callback = function()
    vim.b.autoformat = false
  end,
})

{{- if eq .chezmoi.os "windows" }}

-- 修复 LazyVim chezmoi extra 在 Windows 下保存后不自动 apply 的问题。

-- LazyVim 的 chezmoi extra 默认使用类似：
--   vim.env.HOME .. "/.local/share/chezmoi/*"
-- 这样的 autocmd pattern 来判断是否需要 watch。
-- 而 chezmoi.nvim 的自动 apply 依赖 watch(bufnr) 创建 BufWritePost autocmd。
-- 所以这里手动判断当前 buffer 是否位于 Windows chezmoi source dir 下，
-- 如果是，就主动调用 chezmoi.nvim 的 watch。
do
  local function normalize_path(path)
    if not path or path == "" then
      return nil
    end

    -- 转绝对路径，并把 Windows 反斜杠统一成正斜杠。
    path = vim.trim(path)
    path = vim.fn.fnamemodify(path, ":p")
    path = path:gsub("\\", "/"):gsub("/+$", "")

    return path
  end

  -- HOME 已经在 options.lua 里提前修正为 / 风格路径。
  local chezmoi_source_path = normalize_path((vim.env.HOME or vim.env.USERPROFILE) .. "/.local/share/chezmoi")

  local function is_chezmoi_source_buffer(bufnr)
    if not chezmoi_source_path then
      return false
    end

    local bufname = normalize_path(vim.api.nvim_buf_get_name(bufnr))

    if not bufname then
      return false
    end

    -- Windows 文件路径大小写不敏感，所以统一转小写后比较。
    local source_lower = chezmoi_source_path:lower()
    local buf_lower = bufname:lower()

    -- 当前 buffer 要么就是 source dir 本身，
    -- 要么位于 ~/.local/share/chezmoi/ 下。
    return buf_lower == source_lower or vim.startswith(buf_lower, source_lower .. "/")
  end

  local function watch_chezmoi_buffer(bufnr)
    if not vim.api.nvim_buf_is_valid(bufnr) then
      return
    end

    -- 避免同一个 buffer 重复注册 watch。
    if vim.b[bufnr].personal_chezmoi_windows_watch then
      return
    end

    if not is_chezmoi_source_buffer(bufnr) then
      return
    end

    vim.b[bufnr].personal_chezmoi_windows_watch = true

    -- 延迟到当前事件结束后再 require chezmoi.nvim，
    -- 避免插件尚未完全加载时直接 require 失败。
    vim.schedule(function()
      if not vim.api.nvim_buf_is_valid(bufnr) then
        return
      end

      local ok, edit = pcall(require, "chezmoi.commands.__edit")

      if ok and edit and edit.watch then
        edit.watch(bufnr)
      else
        -- 如果 chezmoi.nvim 这次还没加载成功，
        -- 清掉标记，允许后续 BufRead/BufAdd 再尝试。
        vim.b[bufnr].personal_chezmoi_windows_watch = false
      end
    end)
  end

  vim.api.nvim_create_autocmd({ "BufRead", "BufNewFile", "BufAdd" }, {
    group = vim.api.nvim_create_augroup("personal_chezmoi_windows_watch", { clear = true }),

    -- 不依赖 Windows 路径 pattern。
    -- 统一用 "*" 捕获后在 Lua callback 里做路径归一化和大小写不敏感判断。
    pattern = "*",

    callback = function(ev)
      watch_chezmoi_buffer(ev.buf)
    end,
  })

  -- autocmds.lua 是 VeryLazy 后加载的。
  -- 如果当前 buffer 在这个 autocmd 创建前已经打开，
  -- 这里主动扫描一次已有 buffer，补上 chezmoi watch。
  vim.schedule(function()
    for _, bufnr in ipairs(vim.api.nvim_list_bufs()) do
      watch_chezmoi_buffer(bufnr)
    end
  end)
end

{{- end }}

{{- if ne .chezmoi.os "windows" }}
vim.api.nvim_create_autocmd("FileType", {
  pattern = { "markdown" },
  callback = function()
    -- 禁用自动换行
    vim.opt_local.wrap = false
    -- 水平滚动光标右侧缓冲距离
    vim.opt_local.sidescrolloff = 58
    -- 每次滚动 1 个字符，而不是一次跳半屏
    vim.opt_local.sidescroll = 1
  end,
})
{{- end }}

if not vim.g.vscode then
{{- if and (eq .chezmoi.os "linux") (not .isWsl) }}

  -- Fcitx5 输入法自动切换
  -- 离开插入模式关闭输入法，回到插入模式恢复之前的状态
  local fcitx5_group = vim.api.nvim_create_augroup("Fcitx5Shell", { clear = true })
  local fcitx_state = "1" -- 默认 1 为英文状态

  vim.api.nvim_create_autocmd("InsertLeave", {
    group = fcitx5_group,
    pattern = "*",
    callback = function()
      -- 获取当前状态: 1=Inactive, 2=Active
      local handle = io.popen("fcitx5-remote")
      if handle then
        local result = handle:read("*a")
        handle:close()
        fcitx_state = result:sub(1, 1)
        -- 离开时切换回英文 (Close)
        os.execute("fcitx5-remote -c")
      end
    end,
  })

  vim.api.nvim_create_autocmd("InsertEnter", {
    group = fcitx5_group,
    pattern = "*",
    callback = function()
      -- 如果离开前是中文状态 (2)，进入时重新开启 (Open)
      if fcitx_state == "2" then
        os.execute("fcitx5-remote -o")
      end
    end,
  })
{{- end }}

  -- 退出 nvim 后恢复默认光标
  vim.api.nvim_create_autocmd("VimLeave", {
    group = vim.api.nvim_create_augroup("RestoreCursor", { clear = true }),
    callback = function()
      -- 重置 guicursor 选项
      vim.opt.guicursor = ""
      -- 使用 chansend 向 stderr 发送 "\27[ q" (重置为终端默认形状)
      -- \27 是 Esc 键的转义码
      vim.fn.chansend(vim.v.stderr, "\27[ q")
    end,
  })

{{- /* 只有系统里能找到 PowerShell 时，才渲染这些终端 buffer 专用 autocmd */ -}}
{{- $hasPwsh := lookPath "pwsh" -}}
{{- $hasWindowsPS := lookPath "powershell" -}}
{{- if or $hasPwsh $hasWindowsPS }}

  local augroup = vim.api.nvim_create_augroup("personal_powershell", { clear = true })

  local function add_powershell_terminal_keymaps(buf, lhs, rhs, desc)
    local ok_wk, wk = pcall(require, "which-key")

    if ok_wk then
      wk.add({
        {
          "<leader>l",
          group = "PowerShell",
          icon = " ",
          mode = "n",
          buffer = buf,
        },
        {
          "<leader>lw",
          desc = "Lazy",
          mode = "n",
          buffer = buf,
        },
      })
    end

    vim.keymap.set("n", lhs, rhs, { buffer = buf, desc = desc })
  end

  -- 在 powershell.nvim 打开的普通终端 buffer 中，补上 <leader>lt
  vim.api.nvim_create_autocmd("User", {
    group = augroup,
    pattern = "powershell.nvim-term",
    callback = function(opts)
      local buf = opts.data and opts.data.buf or 0
      add_powershell_terminal_keymaps(buf, "<leader>lt", function()
        require("powershell").toggle_term()
      end, "PowerShell Toggle Terminal")
    end,
  })

  -- 在 powershell.nvim 打开的调试终端 buffer 中，补上 <leader>ld
  vim.api.nvim_create_autocmd("User", {
    group = augroup,
    pattern = "powershell.nvim-debug_term",
    callback = function(opts)
      local buf = opts.data and opts.data.buf or 0
      add_powershell_terminal_keymaps(buf, "<leader>ld", function()
        require("powershell").toggle_debug_term()
      end, "PowerShell Toggle Debug Terminal")
    end,
  })
{{- end }}
end
