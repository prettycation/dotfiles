{{- $hasemmylua_ls := lookPath "emmylua_ls" -}}
{{- $hasTinymist := lookPath "tinymist" -}}
{{- $hasTypstyle := lookPath "typstyle" -}}
{{- $hasRimeLs := lookPath "rime-ls" -}}

return {
  {
    "neovim/nvim-lspconfig",
    opts = function(_, opts)
      opts.servers = opts.servers or {}

      {{ if $hasemmylua_ls }}
      -- EmmyLua LS
      -- 完全禁用 lua-language-server，避免 lua_ls 和 emmylua_ls 同时附着到同一个 Lua buffer。
      opts.servers.lua_ls = {
        enabled = false,
        mason = false,
      }

      local emmylua_cmd = vim.fn.exepath("emmylua_ls")
      if emmylua_cmd == "" then
        emmylua_cmd = vim.fs.joinpath(vim.uv.os_homedir(), ".cargo", "bin", "emmylua_ls")
      end

      opts.servers.emmylua_ls = vim.tbl_deep_extend("force", opts.servers.emmylua_ls or {}, {
        mason = false,
        cmd = { emmylua_cmd },
        filetypes = { "lua" },
        root_markers = {
          ".emmyrc.json",
          ".luarc.json",
          ".luacheckrc",
          ".git",
        },
        workspace_required = false,
      })
      {{ else }}
      -- Lua LS
      opts.servers.lua_ls = opts.servers.lua_ls or {}
      opts.servers.lua_ls.settings = opts.servers.lua_ls.settings or {}
      opts.servers.lua_ls.settings.Lua = vim.tbl_deep_extend(
        "force",
        opts.servers.lua_ls.settings.Lua or {},
        {
          workspace = {
            checkThirdParty = false, -- 推荐关闭
            -- 清空 ignoreDir，否则插件内的 /lua 目录会被跳过
            ignoreDir = {},
            -- 禁止更深入的库搜索
            pathStrict = true,
          },
          completion = {
            callSnippet = "Replace",
          },
          -- 诊断设置
          diagnostics = {
            -- 忽略一些在模板文件中常见的、由于跨插件引用导致的注解警告
            disable = { "undefined-doc-name", "undefined-field" },
          },
        }
      )
      {{ end }}

      -- BasedPyright
      opts.servers.basedpyright = opts.servers.basedpyright or {}
      opts.servers.basedpyright.settings = opts.servers.basedpyright.settings or {}
      opts.servers.basedpyright.settings.basedpyright =
        opts.servers.basedpyright.settings.basedpyright or {}
      opts.servers.basedpyright.settings.basedpyright.analysis = vim.tbl_deep_extend(
        "force",
        opts.servers.basedpyright.settings.basedpyright.analysis or {},
        {
          -- 类型检查级别
          -- "off" / "basic" / "standard" / "strict" / "recommended" / "all"
          -- 推荐将这个选项设置到 pyproject.toml / pyrightconfig.json 里，
          -- 这样 CLI 和 LSP 行为会一致。
          typeCheckingMode = "basic",
          -- 自动搜索常见源码路径
          -- 当项目里没有显式定义 execution environments 时，
          -- basedpyright 会自动把像 "src" 这样的常见目录加入搜索路径。
          autoSearchPaths = true,
          -- 在没有类型 stub 时，允许读取第三方库源码推断类型
          -- 开启后，basedpyright 会在缺少 .pyi stub 的情况下，
          -- 直接读取库源码来补充类型信息。
          useLibraryCodeForTypes = true,
          -- 只分析当前打开的文件
          -- CI 可以再改成 "workspace"。
          diagnosticMode = "openFilesOnly",
        }
      )

      -- Tinymist
      opts.servers.tinymist = opts.servers.tinymist or {}
      {{- if $hasTinymist }}
      -- 如果系统里已经能找到 tinymist，
      -- 就不要再让 Mason 接管它，直接使用系统里的可执行文件。
      opts.servers.tinymist.mason = false
      {{- end }}
      opts.servers.tinymist.settings = vim.tbl_deep_extend(
        "force",
        opts.servers.tinymist.settings or {},
        {
          -- 禁止保存时自动导出 PDF。
          -- 避免每次保存都触发额外动作。
          exportPdf = "never",
          {{- if $hasTypstyle }}
          -- 只有在系统里存在 typstyle 时，才显式启用 typstyle 作为格式化后端。
          -- 如果 typstyle 不在 PATH 中，就不渲染这一项，
          -- 让 tinymist / LazyVim extra 保持默认行为。
          formatterMode = "typstyle",
          {{- end }}
          -- 启用语义高亮增强。
          -- 对某些主题、LSP 高亮或符号语义区分会更有帮助。
          semanticTokens = "enable",
        }
      )

    {{- if $hasRimeLs }}
    -- rime-ls

    -- 这是一个“输入法型 LSP”，用途和普通语言服务器不同：
    -- 它主要把 Rime 的候选结果通过 LSP completion 提供给编辑器。
    local rimedir = vim.fs.joinpath(vim.uv.os_homedir(), ".local", "share", "rime-ls")

    opts.servers.rime_ls = {
      mason = false,
      cmd = { "rime-ls" },

      -- 限定在“更像输入法场景”的 buffer 中启用。
      filetypes = {
        "text",
        "markdown",
        "typst",
        "gitcommit",
      },

      -- 让它按单文件工作，而不是强依赖项目根目录。
      -- 对 rime-ls 这种“输入法型 LSP”来说，通常比复杂的 root_dir 判定更稳定。
      single_file_support = true,

      init_options = {
        -- 是否启用 rime-ls。
        enabled = true,

        -- 系统共享数据目录。
        -- shared_data_dir = rimedir,
        user_data_dir = rimedir,
        log_dir = rimedir,

        -- 对 blink.cmp 很重要。
        -- 让 rime-ls 返回更长的 filter_text，尽量减少候选被 blink 过滤掉的概率。
        long_filter_text = true,

        -- 是否默认选中第一项候选。
        preselect_first = true,

        -- 是否每次都强制重新生成完整候选，而不是依赖客户端过滤。
        always_incomplete = false,

        -- 在候选 label 中显示序号，方便把编辑器补全菜单当作输入法候选列表来用。
        show_order_in_label = true,

        -- 暂时不启用翻页字符。
        -- blink 在这块历史上有兼容性问题，先保持保守配置。
        -- paging_characters = { ",", ".", "-", "=" },
      },
    }
    {{- end }}
    end,
  },
}
{{/* vim: set ft=lua.chezmoitemplate: */}}
