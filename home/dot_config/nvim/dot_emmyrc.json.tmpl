{{- $hasemmylua_ls := lookPath "emmylua_ls" -}}
{{ if $hasemmylua_ls }}
{
  "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
  "completion": {
    "autoRequire": true,
    "callSnippet": false,
    "postfix": "@"
  },
  "diagnostics": {
    "globals": ["vim"],
    "disable": ["undefined-field", "type-not-found"]
  },
  "doc": {
    "syntax": "md"
  },
  "runtime": {
    "version": "LuaJIT",
    "requirePattern": [
      "lua/?/init.lua",
      "lua/?.lua",
      "?/lua/?/init.lua",
      "?/lua/?.lua",
      "?.lua",
      "?/init.lua"
    ]
  },
  "workspace": {
    "workspaceRoots": ["."],
    "library": [
      "$VIMRUNTIME",
      "$HOME/.local/share/nvim/lazy",
      "$HOME/.local/share/nvim/lazy/luacats-luv/library"
    ],
    "ignoreGlobs": ["**/*_spec.lua", "**/test/**", "**/tests/**"]
  }
}
{{ end }}
