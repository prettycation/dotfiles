{{- $hasTv := lookPath "tv" -}}
{{- $hasRecycleBinCli := lookPath "trash-list" -}}
{{- $hasMediainfo := lookPath "mediainfo" -}}
{{- $hasDuckdb := lookPath "duckdb" -}}
{{- $hasSudo := lookPath "sudo" -}}

# A TOML linter such as https://taplo.tamasfe.dev/ can use this schema to validate your config.
# If you encounter any issues, please make an issue at https://github.com/yazi-rs/schemas.
"$schema" = "https://yazi-rs.github.io/schemas/keymap.json"

[mgr]
prepend_keymap = [
  # ---------------------------------------------------------------------------
  # 插件与行为覆盖
  # ---------------------------------------------------------------------------

  # smart-filter
  { on = "F", run = "plugin smart-filter", desc = "智能过滤器" },

  # zoom
  { on = "+", run = "plugin zoom 1", desc = "放大悬停文件" },
  { on = "_", run = "plugin zoom -1", desc = "缩小悬停文件" },

  {{- if $hasTv }}
  # tv
  { on = "<C-f>", run = "plugin tv", desc = "通过 television 跳转到文件" },
  { on = "<C-t>", run = "plugin tv text", desc = "使用 Neovim 打开文件并跳转到匹配文本" },
  { on = "<C-d>", run = "plugin tv dirs", desc = "通过 television 跳转到目录" },
  {{- end }}

  # easyjump
  { on = "f", run = "plugin easyjump", desc = "EasyJump" },

  # searchjump
  { on = "s", run = "plugin searchjump", desc = "SearchJump" },

  # projects
  { on = ["P", "s"], run = "plugin projects save", desc = "保存当前项目" },
  { on = ["P", "l"], run = "plugin projects load", desc = "加载项目" },
  { on = ["P", "P"], run = "plugin projects load_last", desc = "加载最近的项目" },
  { on = ["P", "d"], run = "plugin projects delete", desc = "删除项目" },
  { on = ["P", "D"], run = "plugin projects delete_all", desc = "删除所有项目" },
  { on = ["P", "m"], run = "plugin projects 'merge current'", desc = "将当前 tab 合并到另一个项目" },
  { on = ["P", "M"], run = "plugin projects 'merge all'", desc = "将当前项目合并到另一个项目" },
  { on = ["P", "u"], run = "plugin projects 'load chezmoi'", desc = "加载 chezmoi 项目" },

  {{- if $hasRecycleBinCli }}
  # recycle-bin
  { on = ["R", "o"], run = "plugin recycle-bin -- open",      desc = "打开回收站" },
  { on = ["R", "e"], run = "plugin recycle-bin -- empty",     desc = "清空回收站" },
  { on = ["R", "D"], run = "plugin recycle-bin -- emptyDays", desc = "按删除天数清空回收站" },
  { on = ["R", "d"], run = "plugin recycle-bin -- delete",    desc = "从回收站删除" },
  { on = ["R", "r"], run = "plugin recycle-bin -- restore",   desc = "从回收站恢复" },
  {{- end }}

  {{- if $hasMediainfo }}
  # mediainfo
  { on = "<F9>", run = "plugin mediainfo -- toggle-metadata", desc = "切换媒体预览元数据显示" },
  {{- end }}

  {{- if $hasDuckdb }}
  # duckdb
  # 覆盖默认的 H / L（back / forward），改为表格横向滚动。
  { on = "H", run = "plugin duckdb -1", desc = "向左滚动一列表格" },
  { on = "L", run = "plugin duckdb +1", desc = "向右滚动一列表格" },
  { on = ["g", "o"], run = "plugin duckdb -open", desc = "使用 DuckDB 打开" },
  { on = ["g", "u"], run = "plugin duckdb -ui", desc = "在 DuckDB UI 中打开" },
  {{- end }}

  {{- if $hasSudo }}
  # sudo cp/mv
  { on = [
    "S",
    "p",
    "p",
  ], run = "plugin sudo -- paste", desc = "sudo paste" },

  # sudo cp/mv --force
  { on = [
    "S",
    "P",
  ], run = "plugin sudo -- paste --force", desc = "sudo paste force" },

  # sudo open editor
  { on = [
    "S",
    "o",
  ], run = "plugin sudo -- open", desc = "sudo open editor" },

  # sudo mv
  { on = [
    "S",
    "r",
  ], run = "plugin sudo -- rename", desc = "sudo rename" },

  # sudo ln -s (absolute-path)
  { on = [
    "S",
    "p",
    "l",
  ], run = "plugin sudo -- link", desc = "sudo link" },

  # sudo ln -s (relative-path)
  { on = [
    "S",
    "p",
    "r",
  ], run = "plugin sudo -- link --relative", desc = "sudo link relative path" },

  # sudo ln
  { on = [
    "S",
    "p",
    "L",
  ], run = "plugin sudo -- hardlink", desc = "sudo hardlink" },

  # sudo touch/mkdir
  { on = [
    "S",
    "a",
  ], run = "plugin sudo -- create", desc = "sudo create" },

  # sudo delete
  { on = [
    "S",
    "d",
  ], run = "plugin sudo -- remove --permanently", desc = "sudo delete" },
  {{- end }}

  {{- if eq .chezmoi.os "windows" }}
  # Windows 驱动器跳转：覆盖默认的 g c / g d / g f，并新增 g e。
  { on = ["g", "d"], run = "cd D:", desc = "前往 D: 盘" },
  { on = ["g", "c"], run = "cd C:", desc = "前往 C: 盘" },
  { on = ["g", "e"], run = "cd E:", desc = "前往 E: 盘" },
  { on = ["g", "f"], run = "cd F:", desc = "前往 F: 盘" },
  {{- end }}

  # tabs
  # 覆盖默认的 t 系列前缀，用单键 t 直接在当前工作目录创建新标签页。
  { on = "t", run = "tab_create --current", desc = "使用当前工作目录创建新标签页" },
]

[input]
prepend_keymap = [
]

[confirm]
prepend_keymap = [
  # ---------------------------------------------------------------------------
  # 确认框行为覆盖
  # ---------------------------------------------------------------------------

  # 禁用默认的 y 确认，改为使用 <space> 确认。
  { on = "y", run = "noop" },
  { on = "<Space>", run = "close --submit", desc = "提交确认（Space）" },
]
{{/* vim: set ft=toml.chezmoitemplate: */}}
