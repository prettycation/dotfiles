{{- $hasSoffice := lookPath "soffice" -}}
{{- $hasStarship := lookPath "starship" -}}
{{- $hasMediaInfo := lookPath "mediainfo" -}}
{{- $hasDuckDB := lookPath "duckdb" -}}
{{- $hasRecycleBinCli := lookPath "trash-list" -}}

[[plugin.deps]]
use = "yazi-rs/plugins:smart-filter"

[[plugin.deps]]
use = "yazi-rs/plugins:zoom"

[[plugin.deps]]
use = "cap153/tv"

{{- if $hasStarship }}
[[plugin.deps]]
use = "Rolv-Apneseth/starship"
{{- end }}

[[plugin.deps]]
use = "mikavilpas/easyjump.yazi:easyjump"

{{- if $hasSoffice }}
[[plugin.deps]]
use = "prettycation/office"
{{-   if eq .chezmoi.os "windows" }}
rev = "fix/windows-compatibility"
{{-   end }}
{{- end }}

[[plugin.deps]]
use = "MasouShizuka/projects"

[[plugin.deps]]
use = "DreamMaoMao/searchjump"

[[plugin.deps]]
use = "yazi-rs/plugins:full-border"

{{- if $hasMediaInfo }}
[[plugin.deps]]
use = "boydaihungst/mediainfo"
{{- end }}

{{- if $hasDuckDB }}
[[plugin.deps]]
use = "wylie102/duckdb"
{{- end }}

{{- if $hasRecycleBinCli }}
[[plugin.deps]]
use = "uhs-robert/recycle-bin"
{{- end }}

[flavor]
deps = []
