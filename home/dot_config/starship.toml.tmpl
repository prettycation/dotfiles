{{- $hasNode := or (ne (lookPath "node") "") (ne (lookPath "nodejs") "") -}}
{{- $hasBun := ne (lookPath "bun") "" -}}
{{- $hasPython := or (ne (lookPath "python") "") (ne (lookPath "python3") "") -}}
{{- $hasConda := or (ne (lookPath "conda") "") (ne (lookPath "mamba") "") (ne (lookPath "micromamba") "") -}}
{{- $hasMaven := ne (lookPath "mvn") "" -}}
{{- $hasJava := or (ne (lookPath "java") "") (ne (lookPath "javac") "") -}}
{{- $hasCCompiler := or (ne (lookPath "clang") "") (ne (lookPath "gcc") "") (ne (lookPath "cc") "") (ne (lookPath "clang++") "") (ne (lookPath "g++") "") -}}
{{- $hasCppCompiler := or (ne (lookPath "c++") "") (ne (lookPath "g++") "") (ne (lookPath "clang++") "") -}}
{{- $hasRust := or (ne (lookPath "rustc") "") (ne (lookPath "cargo") "") -}}
{{- $hasDirenv := ne (lookPath "direnv") "" -}}

"$schema" = "https://starship.rs/config-schema.json"

# 使用 overlay0 作为提示符分隔符颜色，低调的灰色
format = """\
[╭╴](fg:overlay0)\
$os\
$username\
{{/* $hostname\ */}}
$vcs\
(\
    [at](fg:text) \
    $directory\
)\
$cmd_duration\
$line_break\
[╰─](fg:overlay0)\
$python\
$conda\
$direnv\
$nodejs\
$bun\
$maven\
$java\
$c\
$cpp\
$rust\
$status\
$character\
"""

# Disable the blank line at the start of the prompt
# prompt 已经是双行，设为 false，避免 Starship 再额外插入一行空白
add_newline = false

palette = "catppuccin_mocha"

[palettes.catppuccin_mocha]
rosewater = {{ .catppuccin.rosewater | quote }}
flamingo = {{ .catppuccin.flamingo | quote }}
pink = {{ .catppuccin.pink | quote }}
mauve = {{ .catppuccin.mauve | quote }}
red = {{ .catppuccin.red | quote }}
maroon = {{ .catppuccin.maroon | quote }}
peach = {{ .catppuccin.peach | quote }}
yellow = {{ .catppuccin.yellow | quote }}
green = {{ .catppuccin.green | quote }}
teal = {{ .catppuccin.teal | quote }}
sky = {{ .catppuccin.sky | quote }}
sapphire = {{ .catppuccin.sapphire | quote }}
blue = {{ .catppuccin.blue | quote }}
lavender = {{ .catppuccin.lavender | quote }}
text = {{ .catppuccin.text | quote }}
subtext1 = {{ .catppuccin.subtext1 | quote }}
subtext0 = {{ .catppuccin.subtext0 | quote }}
overlay2 = {{ .catppuccin.overlay2 | quote }}
overlay1 = {{ .catppuccin.overlay1 | quote }}
overlay0 = {{ .catppuccin.overlay0 | quote }}
surface2 = {{ .catppuccin.surface2 | quote }}
surface1 = {{ .catppuccin.surface1 | quote }}
surface0 = {{ .catppuccin.surface0 | quote }}
base = {{ .catppuccin.base | quote }}
mantle = {{ .catppuccin.mantle | quote }}
crust = {{ .catppuccin.crust | quote }}

[username]
style_user = "bold sky" # 操作系统标识，醒目的天蓝色
style_root = "bold red" # 管理员权限！使用红色作为强烈的警告
format = "[$user]($style) "
disabled = false
show_always = true
# aliases = { "corpuser034g" = "gao", "gaohuan" = "gao" }

# [hostname]
# ssh_only = false
# format = "[@$hostname]($style) "
# style = "bold fg:overlay1"
# aliases = {
#   "My-MacBook-Pro" = "mbp",
#   "DESKTOP-XXXXXXX" = "wsl",
#   "arch-devbox" = "arch"
# }
# disabled = false

[os]
format = "[$symbol]($style)"
style = "bold sky" # 操作系统标识，醒目的天蓝色
disabled = false

[os.symbols]
Alpine = " "
Arch = " "
Debian = " "
EndeavourOS = " "
Fedora = " "
Linux = " "
Macos = " "
Manjaro = " "
Mint = " "
NixOS = " "
openSUSE = " "
Pop = " "
SUSE = " "
Ubuntu = " "
Windows = " "

[character]
success_symbol = "[󰍟](fg:overlay0)" # 提示符分隔符，低调的灰色
error_symbol = "[󰍟](fg:red)"        # 错误状态使用红色强调

[directory]
format = "[$path](bold $style)[$read_only]($read_only_style) "
# 显示完整路径
truncation_length = 0
style = "fg:blue"                # 目录路径，蓝色是最适合文件系统的颜色
read_only_style = "fg:blue"      # 目录路径，蓝色是最适合文件系统的颜色
before_repo_root_style = "fg:lavender"  # repo root 前缀，着浅色
repo_root_style = "bold fg:blue" # 目录路径，蓝色是最适合文件系统的颜色
repo_root_format = "[$before_root_path]($before_repo_root_style)[$repo_root]($repo_root_style)[$path]($style)[$read_only]($read_only_style) "
truncation_symbol = "…/"
# 在 git 仓库中显示完整的绝对路径
truncate_to_repo = false
home_symbol = "~"
read_only = "  "

[time]
disabled = true
format = "at [󱑈 $time]($style)"
time_format = "%H:%M"
style = "bold fg:sapphire" # 时间戳，用蓝宝石色与目录区分

[cmd_duration]
format = "took [ $duration]($style) "
style = "bold fg:red" # 命令执行时间过长，用红色提示
min_time = 500

[vcs]
git_modules = "$git_branch$git_status"

[git_branch]
format = "via [$symbol$branch]($style) "
style = "bold fg:peach" # Git 分支，桃色温暖而清晰
symbol = " "
ignore_bare_repo = true

[git_status]
format = '([\[$conflicted$stashed$untracked$renamed$worktree_added$worktree_modified$worktree_deleted$worktree_typechanged$index_added$index_modified$index_deleted$index_typechanged$ahead_behind\]]($style) )'
style = "fg:crust bg:peach" # Git 状态文本使用高对比前景，背景与 Git 分支共享桃色

conflicted = "[=${count}]"
stashed = "[$${count}]"
untracked = "[?${count}]"
renamed = "[R${count}]"

worktree_added = "[+${count}]"
worktree_modified = "[!${count}]"
worktree_deleted = "[-${count}]"
worktree_typechanged = "[~${count}]"

index_added = "[A${count}]"
index_modified = "[M${count}]"
index_deleted = "[D${count}]"
index_typechanged = "[T${count}]"

ahead = "[⇡${count}]"
behind = "[⇣${count}]"
diverged = "[⇕⇡${ahead_count}⇣${behind_count}]"
up_to_date = "[✓]"

[docker_context]
disabled = true
symbol = " "

[package]
disabled = true

[fill]
symbol = " "

[nodejs]
format = "[ $symbol$version ]($style)"
style = "bg:green fg:crust" # Node.js 环境，绿色代表健康和稳定
symbol = " "
version_format = "${raw}"
disabled = {{ if $hasNode }}false{{ else }}true{{ end }}

[bun]
format = "[ $symbol$version ]($style)"
style = "bg:green fg:crust" # Bun 沿用 Node.js 的绿色语义
symbol = "🥟 "
version_format = "${raw}"
disabled = {{ if $hasBun }}false{{ else }}true{{ end }}

[python]
disabled = {{ if $hasPython }}false{{ else }}true{{ end }}
format = '[ $symbol$version( \($virtualenv\)) ]($style)'
symbol = " "
version_format = "${raw}"
python_binary = "python3"
style = "bg:yellow fg:crust" # Python 环境，黄色是 Python 的标志色之一
generic_venv_names = [".venv", "venv"]

[conda]
format = "[ $symbol$environment ]($style)"
style = "bg:green fg:crust" # Conda 环境，同样使用绿色
ignore_base = true
disabled = {{ if $hasConda }}false{{ else }}true{{ end }}
symbol = " "

[direnv]
format = "[ $symbol$loaded/$allowed ]($style)"
symbol = "direnv "
style = "fg:overlay1"
disabled = {{ if $hasDirenv }}false{{ else }}true{{ end }}

[maven]
format = "[ $symbol$version ]($style)"
style = "bg:red fg:crust" # Java 生态，红色系
version_format = "${raw}"
symbol = "mvn "
recursive = true
disabled = {{ if $hasMaven }}false{{ else }}true{{ end }}

[java]
format = "[ $symbol$version ]($style)"
style = "bg:red fg:crust" # Java 环境，红色系
version_format = "${raw}"
symbol = " "
disabled = {{ if $hasJava }}false{{ else }}true{{ end }}

[c]
format = "[ $symbol($version(-$name)) ]($style)"
style = "bg:sapphire fg:crust" # C/C++ 环境
symbol = " "
version_format = "${raw}"
disabled = {{ if $hasCCompiler }}false{{ else }}true{{ end }}

[cpp]
format = "[ $symbol($version(-$name)) ]($style)"
style = "bg:sapphire fg:crust" # C/C++ 环境
symbol = " "
version_format = "${raw}"
disabled = {{ if $hasCppCompiler }}false{{ else }}true{{ end }}

[rust]
format = "[ $symbol$version ]($style)"
style = "bg:peach fg:crust" # Rust 环境，与 Git 共享桃色
symbol = " "
version_format = "${raw}"
disabled = {{ if $hasRust }}false{{ else }}true{{ end }}

[status]
disabled = false
format = "[$symbol$status]($style) "
symbol = "✘ "
success_symbol = ""
pipestatus = true
pipestatus_separator = "|"
success_style = "fg:overlay1"
failure_style = "bold fg:red"
style = "bold fg:red" # 错误状态用红色强调

{{/* vim: set ft=toml.chezmoitemplate: */}}
