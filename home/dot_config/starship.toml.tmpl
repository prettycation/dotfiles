{{- $hasNode := or (ne (lookPath "node") "") (ne (lookPath "nodejs") "") -}}
{{- $hasPython := or (ne (lookPath "python") "") (ne (lookPath "python3") "") -}}
{{- $hasConda := or (ne (lookPath "conda") "") (ne (lookPath "mamba") "") (ne (lookPath "micromamba") "") -}}
{{- $hasMaven := ne (lookPath "mvn") "" -}}
{{- $hasJava := or (ne (lookPath "java") "") (ne (lookPath "javac") "") -}}
{{- $hasCCompiler := or (ne (lookPath "clang") "") (ne (lookPath "gcc") "") (ne (lookPath "cc") "") (ne (lookPath "clang++") "") (ne (lookPath "g++") "") -}}
{{- $hasRust := or (ne (lookPath "rustc") "") (ne (lookPath "cargo") "") -}}

"$schema" = "https://starship.rs/config-schema.json"

format = """\
[╭╴](fg:arrow)\
$os\
$username\
$vcs\
(\
    [at](fg:overlay1) \
    $directory\
)\
$cmd_duration\
$line_break\
[╰─](fg:arrow)\
$python\
$conda\
$nodejs\
$maven\
$java\
$c\
$rust\
$character\
"""

# Disable the blank line at the start of the prompt
# prompt 已经是双行，设为 false，避免 Starship 再额外插入一行空白
add_newline = false

palette = "catppuccin_mocha"

[palettes.catppuccin_mocha]
rosewater = "#f5e0dc"
flamingo = "#f2cdcd"
pink = "#f5c2e7"
mauve = "#cba6f7"
red = "#f38ba8"
maroon = "#eba0ac"
peach = "#fab387"
yellow = "#f9e2af"
green = "#a6e3a1"
teal = "#94e2d5"
sky = "#89dceb"
sapphire = "#74c7ec"
blue = "#89b4fa"
lavender = "#b4befe"
text = "#cdd6f4"
subtext1 = "#bac2de"
subtext0 = "#a6adc8"
overlay2 = "#9399b2"
overlay1 = "#7f849c"
overlay0 = "#6c7086"
surface2 = "#585b70"
surface1 = "#45475a"
surface0 = "#313244"
base = "#1e1e2e"
mantle = "#181825"
crust = "#11111b"

# text_light = "#26272A"

# --- Catppuccin Mocha 风格 ---
arrow = "#6c7086"      # (Overlay0) 提示符分隔符，低调的灰色
os = "#89dceb"         # (Sky) 操作系统标识，醒目的天蓝色
os_admin = "#f38ba8"   # (Red) 管理员权限！使用红色作为强烈的警告
directory = "#89b4fa"  # (Blue) 目录路径，蓝色是最适合文件系统的颜色
time = "#74c7ec"       # (Sapphire) 时间戳，用蓝宝石色与目录区分
node = "#a6e3a1"       # (Green) Node.js 环境，绿色代表健康和稳定
git = "#fab387"        # (Peach) Git 分支，桃色温暖而清晰
git_status = "#cdd6f4" # (Text) Git 状态文本，使用标准文字颜色
python = "#f9e2af"     # (Yellow) Python 环境，黄色是 Python 的标志色之一
conda = "#a6e3a1"      # (Green) Conda 环境，同样使用绿色
java = "#f38ba8"       # (Red) Java 环境，红色系
rust = "#fab387"       # (Peach) Rust 环境，与 Git 共享桃色
clang = "#74c7ec"      # (Sapphire) C/C++ 环境
duration = "#f38ba8"   # (Red) 命令执行时间过长，用红色提示
text_color = "#cdd6f4" # (Text) 默认前景色
text_light = "#11111b" # (Crust) 用于浅色背景下的文字颜色（最高对比度）
overlay1 = "#7f849c"

[username]
style_user = "bold os"
style_root = "bold os_admin"
format = "[$user]($style) "
disabled = false
show_always = true

[os]
format = "[$symbol]($style)"
style = "bold os"
disabled = false

[os.symbols]
Alpine = " "
Arch = " "
Debian = " "
EndeavourOS = " "
Fedora = " "
Linux = " "
Macos = " "
Manjaro = " "
Mint = " "
NixOS = " "
openSUSE = " "
Pop = " "
SUSE = " "
Ubuntu = " "
Windows = " "

[character]
success_symbol = "[󰍟](fg:arrow)"
error_symbol = "[󰍟](fg:red)"

[directory]
format = "[$path](bold $style)[$read_only]($read_only_style) "
# 显示完整路径
truncation_length = 0
style = "fg:directory"
read_only_style = "fg:directory"
before_repo_root_style = "fg:overlay1"
repo_root_style = "bold fg:directory"
repo_root_format = "[$before_root_path]($before_repo_root_style)[$repo_root]($repo_root_style)[$path]($style)[$read_only]($read_only_style) "
truncation_symbol = "…/"
# 在 git 仓库中显示完整的绝对路径
truncate_to_repo = false
home_symbol = "~"
read_only = "  "

[time]
disabled = true
format = "at [󱑈 $time]($style)"
time_format = "%H:%M"
style = "bold fg:time"

[cmd_duration]
format = "took [ $duration]($style) "
style = "bold fg:duration"
min_time = 500

[vcs]
git_modules = "$git_branch$git_status"

[git_branch]
format = "via [$symbol$branch]($style) "
style = "bold fg:git"
symbol = " "

[git_status]
format = '([\[$conflicted$stashed$untracked$renamed$worktree_added$worktree_modified$worktree_deleted$worktree_typechanged$index_added$index_modified$index_deleted$index_typechanged$ahead_behind\]]($style) )'
style = "fg:text_light bg:git"

conflicted = "[=${count}]"
stashed = "[$${count}]"
untracked = "[?${count}]"
renamed = "[R${count}]"

worktree_added = "[+${count}]"
worktree_modified = "[!${count}]"
worktree_deleted = "[-${count}]"
worktree_typechanged = "[~${count}]"

index_added = "[A${count}]"
index_modified = "[M${count}]"
index_deleted = "[D${count}]"
index_typechanged = "[T${count}]"

ahead = "[⇡${count}]"
behind = "[⇣${count}]"
diverged = "[⇕⇡${ahead_count}⇣${behind_count}]"
up_to_date = "[✓]"

[docker_context]
disabled = true
symbol = " "

[package]
disabled = true

[fill]
symbol = " "

[nodejs]
format = "[ $symbol$version ]($style)"
style = "bg:node fg:text_light"
symbol = " "
version_format = "${raw}"
disabled = {{ if $hasNode }}false{{ else }}true{{ end }}

[python]
disabled = {{ if $hasPython }}false{{ else }}true{{ end }}
format = '[ $symbol$version( \($virtualenv\)) ]($style)'
symbol = " "
version_format = "${raw}"
style = "bg:python fg:text_light"
generic_venv_names = [".venv", "venv"]

[conda]
format = "[ $symbol$environment ]($style)"
style = "bg:conda fg:text_light"
ignore_base = false
disabled = {{ if $hasConda }}false{{ else }}true{{ end }}
symbol = " "

[maven]
format = "[ $symbol$version ]($style)"
style = "bg:java fg:text_light"
version_format = "${raw}"
symbol = "mvn "
disabled = {{ if $hasMaven }}false{{ else }}true{{ end }}

[java]
format = "[ $symbol$version ]($style)"
style = "bg:java fg:text_light"
version_format = "${raw}"
symbol = " "
disabled = {{ if $hasJava }}false{{ else }}true{{ end }}

[c]
format = "[ $symbol($version(-$name)) ]($style)"
style = "bg:clang fg:text_light"
symbol = " "
version_format = "${raw}"
disabled = {{ if $hasCCompiler }}false{{ else }}true{{ end }}

[rust]
format = "[ $symbol$version ]($style)"
style = "bg:rust fg:text_light"
symbol = " "
version_format = "${raw}"
disabled = {{ if $hasRust }}false{{ else }}true{{ end }}
{{/* vim: set ft=toml.chezmoitemplate: */}}
