{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
set -euo pipefail

log_info() {
  printf '[desktop-entries] %s\n' "$*"
}

log_ok() {
  printf '[desktop-entries] ok: %s\n' "$*"
}

log_skip() {
  printf '[desktop-entries] skip: %s\n' "$*"
}

log_warn() {
  printf '[desktop-entries] warn: %s\n' "$*"
}

target_dir="${HOME}/.local/share/applications"
mkdir -p "$target_dir"

hidden=0
skipped=0
failed=0

hide_desktop_file() {
  local desktop_id="$1"
  local source_file="/usr/share/applications/${desktop_id}"
  local target_file="${target_dir}/${desktop_id}"

  if [[ ! -f "$source_file" ]]; then
    log_skip "$desktop_id not found in /usr/share/applications"
    ((skipped += 1))
    return 0
  fi

  if ! cp -f "$source_file" "$target_file"; then
    log_warn "$desktop_id failed to copy"
    ((failed += 1))
    return 0
  fi

  if grep -q '^NoDisplay=' "$target_file" 2>/dev/null; then
    if sed -i 's/^NoDisplay=.*/NoDisplay=true/' "$target_file"; then
      log_ok "$desktop_id hidden"
      ((hidden += 1))
    else
      log_warn "$desktop_id failed to update NoDisplay"
      ((failed += 1))
    fi
  else
    if printf '\nNoDisplay=true\n' >>"$target_file"; then
      log_ok "$desktop_id hidden"
      ((hidden += 1))
    else
      log_warn "$desktop_id failed to append NoDisplay"
      ((failed += 1))
    fi
  fi
}

log_info "hiding selected desktop entries"

apps_to_hide=(
  "lstopo.desktop"
  "avahi-discover.desktop"
  "qv4l2.desktop"
  "qvidcap.desktop"
  "bssh.desktop"
  "org.fcitx.Fcitx5.desktop"
  "org.fcitx.fcitx5-migrator.desktop"
  "xgps.desktop"
  "xgpsspeed.desktop"
  "gvim.desktop"
  "kbd-layout-viewer5.desktop"
  "bvnc.desktop"
  "yazi.desktop"
  "btop.desktop"
  "vim.desktop"
  "nvim.desktop"
  "nvtop.desktop"
  "mpv.desktop"
  "org.gnome.Settings.desktop"
  "thunar-settings.desktop"
  "thunar-bulk-rename.desktop"
  "thunar-volman-settings.desktop"
  "clipse-gui.desktop"
  "waypaper.desktop"
  "xfce4-about.desktop"
  "cmake-gui.desktop"
  "assistant.desktop"
  "qdbusviewer.desktop"
  "linguist.desktop"
  "designer.desktop"
  "org.kde.drkonqi.coredump.gui.desktop"
  "org.kde.kwrite.desktop"
  "org.freedesktop.MalcontentControl.desktop"
  "org.gnome.Nautilus.desktop"
)

for app in "${apps_to_hide[@]}"; do
  hide_desktop_file "$app"
done

log_info "summary: hidden=$hidden skipped=$skipped failed=$failed"

if ((failed > 0)); then
  exit 1
fi
{{- end -}}
