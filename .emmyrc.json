{
  "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
  "completion": {
    "autoRequire": true,
    "callSnippet": false,
    "postfix": "@"
  },
  "diagnostics": {
    "globals": ["vim"],
    "disable": ["type-not-found"],
    "severity": {
      "missing-parameter": "hint",
      "deprecated": "hint"
    }
  },
  "doc": {
    "syntax": "md"
  },
  "runtime": {
    "version": "LuaJIT",
    "requirePattern": [
      "lua/?/init.lua",
      "lua/?.lua",
      "?/lua/?/init.lua",
      "?/lua/?.lua",
      "?.lua",
      "?/init.lua"
    ]
  },
  "workspace": {
    "workspaceRoots": ["home/dot_config/nvim"],
    "library": [
      "$VIMRUNTIME",
      "$HOME/.local/share/nvim/lazy",
      "$HOME/.local/share/nvim/lazy/luacats-luv/library"
    ],
    "ignoreGlobs": ["**/*_spec.lua", "**/test/**", "**/tests/**"]
  }
}
