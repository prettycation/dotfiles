{
  "packageManager": "paru",
  "notes": "Generated by home/.chezmoiscripts/linux/export/run_onchange_after_convert-paru-export.sh.tmpl. Edit home/.chezmoidata/linux/paru.packages.yaml instead.",
  "repositorySources": {
    "core": {
      "type": "pacman-repository",
      "enabledByDefault": true,
      "url": "file:///etc/pacman.d/mirrorlist",
      "pacmanConfig": [
        "[core]",
        "Include = /etc/pacman.d/mirrorlist"
      ]
    },
    "extra": {
      "type": "pacman-repository",
      "enabledByDefault": true,
      "url": "file:///etc/pacman.d/mirrorlist",
      "pacmanConfig": [
        "[extra]",
        "Include = /etc/pacman.d/mirrorlist"
      ]
    },
    "archlinuxcn": {
      "type": "pacman-repository",
      "enabledByDefault": false,
      "url": "https://repo.archlinuxcn.org/$arch",
      "pacmanConfig": [
        "[archlinuxcn]",
        "Server = https://mirrors.cernet.edu.cn/archlinuxcn/$arch"
      ],
      "bootstrapPackages": [
        "archlinuxcn-keyring"
      ]
    },
    "aur": {
      "type": "aur",
      "enabledByDefault": false,
      "url": "https://aur.archlinux.org",
      "helper": "paru"
    }
  },
  "paruGroups": {
    "bootstrap-core-cli": {
      "title": "Bootstrap 核心 CLI",
      "description": "Linux/Arch bootstrap 自举所需的基础工具；这些包必须能在 paru 安装前通过 pacman 安装",
      "selection": "required",
      "promptOrder": 10,
      "installPriority": 10,
      "ui": "cli",
      "domain": "bootstrap",
      "buckets": {
        "core": [
          "base-devel"
        ],
        "extra": [
          "git",
          "jq"
        ]
      },
      "packageOptions": {
        "core": {
          "base-devel": {
            "notes": [
              "AUR / makepkg 构建基础工具集合",
              "paru 自举安装前必须具备"
            ]
          }
        },
        "extra": {
          "git": {
            "notes": [
              "克隆 AUR 仓库与 dotfiles 仓库"
            ]
          },
          "jq": {
            "notes": [
              "shell steps 可用于读取 manifest JSON"
            ]
          }
        }
      }
    },
    "niri-desktop-environment": {
      "title": "Niri 桌面环境",
      "description": "Shorin/Niri 桌面环境、Wayland 组件、输入法、主题、文件管理、多媒体与常用桌面工具",
      "selection": "default",
      "promptOrder": 120,
      "installPriority": 120,
      "ui": "hybrid",
      "domain": "desktop",
      "buckets": {
        "archlinuxcn": [
          "downgrade",
          "nautilus-open-any-terminal",
          "wl-screenrec-git",
          "xdg-terminal-exec"
        ],
        "aur": [
          "cliphist-tui-git",
          "ddcutil-service",
          "linuxqq-clipsync-git",
          "niri-sidebar-git",
          "shorin-contrib-git",
          "shorin-screenrec-menu-git",
          "ttf-jetbrains-maple-mono-nf-xx-xx",
          "ttf-lxgw-wenkai-screen",
          "waypaper-git",
          "wl-longshot-git"
        ],
        "extra": [
          "adw-gtk-theme",
          "bluetui",
          "brightnessctl",
          "btop",
          "cliphist",
          "clipnotify",
          "fcitx5",
          "fcitx5-configtool",
          "fcitx5-gtk",
          "fcitx5-qt",
          "fcitx5-rime",
          "ffmpegthumbnailer",
          "file-roller",
          "fuzzel",
          "gdu",
          "gnome-calendar",
          "gnome-clocks",
          "gnome-keyring",
          "gst-libav",
          "gst-plugins-base",
          "gst-plugins-good",
          "gvfs-gphoto2",
          "gvfs-mtp",
          "gvfs-smb",
          "hyprlock",
          "hyprpicker",
          "icoextract",
          "imagemagick",
          "imv",
          "kitty",
          "libgsf",
          "mako",
          "mpv",
          "nautilus",
          "niri",
          "noto-fonts",
          "noto-fonts-cjk",
          "noto-fonts-emoji",
          "nwg-look",
          "pacman-contrib",
          "pavucontrol",
          "poppler-glib",
          "power-profiles-daemon",
          "satty",
          "strace",
          "swayidle",
          "swayosd",
          "thunar",
          "thunar-archive-plugin",
          "thunar-volman",
          "ttf-jetbrains-mono-nerd",
          "tumbler",
          "waybar",
          "webp-pixbuf-loader",
          "wf-recorder",
          "wl-clipboard",
          "wlsunset",
          "xclip",
          "xdg-desktop-portal-gnome",
          "xdg-desktop-portal-gtk",
          "xwayland-satellite"
        ]
      },
      "packageOptions": {
        "archlinuxcn": {
          "downgrade": {
            "notes": [
              "pacman 软件包降级工具"
            ]
          },
          "xdg-terminal-exec": {
            "notes": [
              "XDG 终端执行协议",
              "nautilus/thunar 等“打开终端”调用"
            ]
          },
          "wl-screenrec-git": {
            "notes": [
              "与 wf-recorder 重复"
            ],
            "selection": "optional"
          },
          "nautilus-open-any-terminal": {
            "notes": [
              "走 thunar 路线，不需要"
            ],
            "selection": "optional"
          }
        },
        "aur": {
          "ttf-lxgw-wenkai-screen": {
            "notes": [
              "霞鹜文楷屏显版（AUR），中文美化"
            ]
          },
          "shorin-screenrec-menu-git": {
            "notes": [
              "录屏菜单 GUI（AUR）",
              "waybar custom/wfrec 模块调用 shorin-screenrec-menu"
            ]
          },
          "shorin-contrib-git": {
            "notes": [
              "⭐ 作者自制工具集（AUR）",
              "提供 shorin/sysup/pac/clean/quicksave/quickload 命令"
            ]
          },
          "waypaper-git": {
            "notes": [
              "壁纸切换 GUI（AUR）",
              "python-pillow 是 waypaper-git 依赖；icoextract 的可选依赖；不装 icoextract 就完全无用",
              "binds.kdl Mod+Alt+W / Mod+F10 + waybar 多处调用"
            ]
          },
          "niri-sidebar-git": {
            "notes": [
              "niri 侧边栏（AUR）",
              "niri 自启动 ~/.local/bin/niri-sidebar listen",
              "binds.kdl Mod+M / Mod+Alt+S/Z/X/R 调用"
            ],
            "selection": "optional"
          },
          "cliphist-tui-git": {
            "notes": [
              "剪贴板 TUI（AUR）",
              "binds.kdl Mod+Alt+V + waybar custom/clipboard 调用",
              "装它会自动拉硬依赖：chafa + ffmpegthumbnailer + fzf",
              "所以不用单独列 chafa/fzf"
            ]
          },
          "ddcutil-service": {
            "notes": [
              "DDC/CI 协议显示器亮度控制（AUR）",
              "waybar group/ddcutil 模块的 3 个按钮调用 ddcutil",
              "安装后还需把当前用户加入 i2c 组并加载 i2c-dev 模块"
            ]
          },
          "linuxqq-clipsync-git": {
            "notes": [
              "X11↔Wayland 剪贴板同步服务（AUR）",
              "修复 Linux QQ 在 Wayland 下复制粘贴异常",
              "niri 自启动 systemctl --user start linuxqq-clipsync",
              "装它会自动拉硬依赖：clipnotify + xclip + wl-clipboard",
              "所以 clipnotify 和 xclip 不用单独列"
            ]
          },
          "wl-longshot-git": {
            "notes": [
              "Wayland 滚动截图（AUR）",
              "waybar custom/screenshot 模块中键调用 wl-longshot"
            ]
          },
          "ttf-jetbrains-maple-mono-nf-xx-xx": {
            "notes": [
              "与 ttf-jetbrains-mono-nerd 重复"
            ],
            "selection": "optional"
          }
        },
        "extra": {
          "niri": {
            "notes": [
              "⭐ 窗口管理器本体"
            ]
          },
          "xwayland-satellite": {
            "notes": [
              "让 X11 应用能在 niri 下运行"
            ]
          },
          "xdg-desktop-portal-gnome": {
            "notes": [
              "Portal 后端，处理屏幕分享/文件选择器",
              "niri/config.kdl 自启动 /usr/lib/xdg-desktop-portal-gnome"
            ]
          },
          "waybar": {
            "notes": [
              "顶栏；niri/config.kdl 自启动 \"waybar\""
            ]
          },
          "mako": {
            "notes": [
              "通知守护；niri/config.kdl 自启动 \"mako\""
            ]
          },
          "swayidle": {
            "notes": [
              "闲置检测后端"
            ]
          },
          "swayosd": {
            "notes": [
              "音量/亮度/CapsLock 的 OSD 弹窗",
              "niri/config.kdl 自启动 \"swayosd-server\"",
              "binds.kdl XF86Audio 等键调用 swayosd-client"
            ]
          },
          "hyprlock": {
            "notes": [
              "锁屏；binds.kdl Mod+Alt+L 绑定",
              "waybar 电源菜单 lockscreen 也调用"
            ]
          },
          "adw-gtk-theme": {
            "notes": [
              "壁纸选择器、thunar 等 gtk 主题，matugen 生成图标需要"
            ]
          },
          "brightnessctl": {
            "notes": [
              "屏幕亮度调节",
              "binds.kdl XF86MonBrightnessUp/Down 绑定"
            ]
          },
          "wlsunset": {
            "notes": [
              "夜间色温/护眼模式",
              "niri 自启动 ~/.local/bin/toggle-wlsunset",
              "waybar ddcutil 模块右键也调用"
            ]
          },
          "hyprpicker": {
            "notes": [
              "颜色拾取",
              "niri-pick 脚本 + waybar custom/colorpicker 模块调用",
              "原 TARGET_SOFTWARE 漏声明"
            ]
          },
          "satty": {
            "notes": [
              "截图标注编辑器"
            ]
          },
          "imagemagick": {
            "notes": [
              "图像处理",
              "matugen-update.sh 第 110 行 magick 转换 webp",
              "random-anime-wallpaper.sh 用 identify 读宽度"
            ]
          },
          "wl-clipboard": {
            "notes": [
              "提供 wl-copy / wl-paste；niri 自启动",
              "spawn-at-startup \"wl-paste\" \"--watch\" \"cliphist\" \"store\""
            ]
          },
          "cliphist": {
            "notes": [
              "剪贴板历史后端"
            ]
          },
          "fuzzel": {
            "notes": [
              "应用启动器（dmenu 风格）",
              "binds.kdl Mod+Z + waybar 多处调用",
              "也可换成 fuzzel-ime-git（带输入法支持）"
            ]
          },
          "kitty": {
            "notes": [
              "⭐ 默认终端",
              "binds.kdl Mod+T/Mod+return 等 6+ 处硬编码",
              "waybar 多个模块的 on-click 也用它"
            ]
          },
          "gnome-keyring": {
            "notes": [
              "密钥环服务；GUI 应用密码/SSH 凭证存储"
            ]
          },
          "fcitx5": {
            "notes": [
              "输入法框架本体；niri 自启动 \"fcitx5\""
            ]
          },
          "fcitx5-gtk": {
            "notes": [
              "GTK 应用输入法支持"
            ]
          },
          "fcitx5-qt": {
            "notes": [
              "Qt 应用输入法支持"
            ]
          },
          "fcitx5-rime": {
            "notes": [
              "Rime 引擎前端"
            ]
          },
          "fcitx5-configtool": {
            "notes": [
              "输入法配置 GUI"
            ]
          },
          "noto-fonts": {
            "notes": [
              "基础西文字体"
            ]
          },
          "noto-fonts-cjk": {
            "notes": [
              "中日韩字体"
            ]
          },
          "noto-fonts-emoji": {
            "notes": [
              "彩色 Emoji"
            ]
          },
          "ttf-jetbrains-mono-nerd": {
            "notes": [
              "⭐ Nerd Font，waybar/kitty 大量图标依赖"
            ]
          },
          "thunar": {
            "notes": [
              "⭐ 文件管理器；binds.kdl Mod+E 优先调用"
            ]
          },
          "tumbler": {
            "notes": [
              "缩略图守护进程（D-Bus 服务）",
              "硬依赖：gdk-pixbuf2 + libxfce4util（自动拉）"
            ]
          },
          "file-roller": {
            "notes": [
              "压缩文件 GUI（thunar 右键解压调用）"
            ]
          },
          "thunar-archive-plugin": {
            "notes": [
              "thunar 右键归档操作"
            ]
          },
          "thunar-volman": {
            "notes": [
              "thunar 自动挂载 U 盘/光盘"
            ]
          },
          "mpv": {
            "notes": [
              "媒体播放器"
            ]
          },
          "imv": {
            "notes": [
              "图片查看器"
            ]
          },
          "ffmpegthumbnailer": {
            "notes": [
              "视频文件缩略图（tumbler optdepend）",
              "同时是 cliphist-tui-git 的硬依赖"
            ]
          },
          "poppler-glib": {
            "notes": [
              "PDF 缩略图（tumbler optdepend）"
            ]
          },
          "libgsf": {
            "notes": [
              "ODF（.odt/.ods 等）缩略图（tumbler optdepend）"
            ]
          },
          "gst-plugins-base": {
            "notes": [
              "GStreamer 基础插件（多媒体框架）"
            ]
          },
          "gst-plugins-good": {
            "notes": [
              "GStreamer 高质量插件"
            ]
          },
          "gst-libav": {
            "notes": [
              "GStreamer 的 ffmpeg 后端（视频解码）"
            ]
          },
          "pavucontrol": {
            "notes": [
              "音量混音器 GUI",
              "waybar pulseaudio 模块中键调用 pavucontrol --tab=3"
            ]
          },
          "wf-recorder": {
            "notes": [
              "wlroots 录屏后端（保留这个，不装 wl-screenrec-git）"
            ]
          },
          "pacman-contrib": {
            "notes": [
              "提供 paccache 等",
              "shorin-contrib 的 sysup/clean 命令依赖"
            ]
          },
          "gnome-clocks": {
            "notes": [
              "时钟 GUI；waybar clock 模块左键调用"
            ]
          },
          "gnome-calendar": {
            "notes": [
              "日历 GUI；waybar clock 模块右键调用"
            ]
          },
          "power-profiles-daemon": {
            "notes": [
              "电源模式控制"
            ]
          },
          "bluetui": {
            "notes": [
              "蓝牙 TUI 管理器",
              "waybar bluetooth 模块左键调用 kitty -e bluetui"
            ]
          },
          "gvfs-mtp": {
            "notes": [
              "GVFS MTP 后端，连接安卓手机文件传输"
            ],
            "selection": "optional"
          },
          "gvfs-gphoto2": {
            "notes": [
              "GVFS PTP 后端，连接数码相机"
            ],
            "selection": "optional"
          },
          "gvfs-smb": {
            "notes": [
              "GVFS SMB 后端，访问 Windows 网络共享"
            ],
            "selection": "optional"
          },
          "xdg-desktop-portal-gtk": {
            "notes": [
              "与 xdg-desktop-portal-gnome 冲突"
            ],
            "selection": "optional"
          },
          "icoextract": {
            "notes": [
              ".exe 图标缩略图，极小众"
            ],
            "selection": "optional"
          },
          "webp-pixbuf-loader": {
            "notes": [
              "给 GTK 应用 webp 显示，niri 桌面无引用"
            ],
            "selection": "optional"
          },
          "nautilus": {
            "notes": [
              "走 thunar 路线，不需要"
            ],
            "selection": "optional"
          },
          "clipnotify": {
            "notes": [
              "仅 linuxqq-clipsync 的硬依赖",
              "不用 QQ 时不需要"
            ],
            "selection": "optional"
          },
          "xclip": {
            "notes": [
              "仅 linuxqq-clipsync 的硬依赖",
              "不用 QQ 时不需要"
            ],
            "selection": "optional"
          },
          "gdu": {
            "notes": [
              "磁盘空间管理 TUI 工具"
            ]
          },
          "nwg-look": {
            "notes": [
              "GTK 主题配置 GUI"
            ]
          },
          "btop": {
            "notes": [
              "fastfetch",
              "matugen 适配"
            ]
          },
          "strace": {
            "notes": [
              "调试工具"
            ]
          }
        }
      }
    },
    "misc-lab": {
